import core/option.{Option, Some, None}

type Point = { x: Int, y: Int }

type Option[a] = Some(a) | None deriving (Eq, Show)

trait Eq[a] {
    fun eq(self: a, other: a) -> Bool
}

impl Eq[Point] {
    fun eq(a, b) = a.x == b.x && a.y == b.y
}

pub fun add(a: Int, b: Int) -> Int = a + b

fun main() -> Int {
    let x = 1;
    let y = 2;
    add(x, y)
}
