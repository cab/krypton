module hkt__impl_vec_distinct_params

declare println: (Dict, m) -> Unit
declare tag: (Dict, q7) -> String

fn main() -> Unit =
  let v0: Vec[Int] = make_vec(1, 2, 3)
  let v1: Vec[String] = make_vec("a", "b", "c")
  let v2: Dict = get_dict Tag[Vec[Int]]
  let v3: String = call tag(v2, v0)
  let v4: Dict = get_dict Show[String]
  let v5: Unit = call println(v4, v3)
  let v7: Dict = get_dict Tag[Vec[String]]
  let v8: String = call tag(v7, v1)
  let v6: Dict = get_dict Show[String]
  let v9: Unit = call println(v6, v8)
  v9
