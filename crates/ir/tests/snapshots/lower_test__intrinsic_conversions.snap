module intrinsic_conversions

; extern concat
; extern intToString
; extern length
; extern println
; extern toFloat
; extern toInt

fn main() -> Unit =
  let v0: Float = call toFloat(1)
  let v1: Int = call toInt(v0)
  let v2: String = call intToString(v1)
  let v3: String = call concat(v2, "ab")
  let v4: Int = call length(v3)
  let v5: Unit = call println(v4)
  v5
