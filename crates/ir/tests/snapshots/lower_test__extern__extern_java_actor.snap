import core/actor/spawn as spawn((Mailbox[p8]) -> Unit): Ref[p8]
import core/actor/send as send(Ref[v8], v8): Unit
import core/actor/receive as receive(Mailbox[g9]): g9
import core/actor/actor_ref as actor_ref(Mailbox[p9]): Ref[p9]
declare actor_ref: (Mailbox[p9]) -> Ref[p9]
declare receive: (Mailbox[g9]) -> g9
declare send: (Ref[v8], v8) -> Unit

fn echo(v0: Mailbox[Int]) -> Unit =
  let v1: Int = call receive(v0)
  let v2: Ref[Int] = call actor_ref(v0)
  let v3: Unit = call send(v2, v1)
  v3

fn use_ref(v4: Ref[Int]) -> Unit =
  let v5: Unit = call send(v4, 42)
  v5

fn main() -> (Mailbox[Int]) -> Unit =
  let v6: (Mailbox[Int]) -> Unit = make_closure(echo, [])
  v6
