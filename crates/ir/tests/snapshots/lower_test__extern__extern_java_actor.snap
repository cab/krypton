declare actor_ref: (Mailbox[a11]) -> Ref[a11]
declare receive: (Mailbox[r10]) -> r10
declare send: (Ref[g10], g10) -> Unit

fn echo(v0: Mailbox[Int]) -> Unit =
  let v1: Int = call receive(v0)
  let v2: Ref[Int] = call actor_ref(v0)
  let v3: Unit = call send(v2, v1)
  v3

fn use_ref(v4: Ref[Int]) -> Unit =
  let v5: Unit = call send(v4, 42)
  v5

fn main() -> (Mailbox[Int]) -> Unit =
  let v6: (Mailbox[Int]) -> Unit = make_closure(echo, [])
  v6
