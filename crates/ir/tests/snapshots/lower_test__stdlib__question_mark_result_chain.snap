      let v18: ~Result[String, Int] = construct Result::Ok#0(v13)
      v18
    in
    let v14: Result[String, Int] = call double(v8)
    switch v14 {
      0 (v15: Int) ->
        jump v19(v15)
      1 (v16: String) ->
        let v17: Result[String, Int] = construct Result::Err#1(v16)
        jump v6(v17)
    }
  in
  let v9: Result[String, Int] = call parse(v5)
  switch v9 {
    0 (v10: Int) ->
      jump v20(v10)
    1 (v11: String) ->
      let v12: Result[String, Int] = construct Result::Err#1(v11)
      jump v6(v12)
  }

fn main() -> Unit =
  let v21: Result[String, Int] = call process(21)
  switch v21 {
