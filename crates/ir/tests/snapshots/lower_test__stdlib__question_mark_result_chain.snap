fn parse(v0: Int) -> Result[String, Int] =
  let v1: ~Result[String, Int] = construct Result::Ok#0(v0)
  v1

fn double(v2: Int) -> Result[String, Int] =
  let v3: Int = mul_int(v2, 2)
  let v4: ~Result[String, Int] = construct Result::Ok#0(v3)
  v4

fn process(v5: Int) -> Result[String, Int] =
  let_join v6(v7: Result[String, Int]) =
    v7
  in
  let_join v20(v8: Int) =
