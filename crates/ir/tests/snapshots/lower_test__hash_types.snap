module hash_types

; extern hash
; extern println

fn main() -> Unit =
  let v0: Int = call hash(42)
  let v1: Int = call hash(42)
  let v2: Bool = eq_int(v0, v1)
  let v3: Unit = call println(v2)
  let v4: Int = call hash(3.14)
  let v5: Int = call hash(3.14)
  let v6: Bool = eq_int(v4, v5)
  let v7: Unit = call println(v6)
  let v8: Int = call hash("hello")
  let v9: Int = call hash("hello")
  let v10: Bool = eq_int(v8, v9)
  let v11: Unit = call println(v10)
  let v12: Int = call hash(true)
  let v13: Int = call hash(true)
  let v14: Bool = eq_int(v12, v13)
  let v15: Unit = call println(v14)
  v15
