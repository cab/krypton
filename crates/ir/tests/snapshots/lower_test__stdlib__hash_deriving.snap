module stdlib__hash_deriving

struct Point { x: Int, y: Int }
declare eq: (Dict, g, g) -> Bool
declare hash: (Dict, g) -> Int
declare println: (Dict, m) -> Unit

fn main() -> Unit =
  let v0: ~Point = construct Point(1, 2)
  let v1: ~Point = construct Point(1, 2)
  let v2: ~Point = construct Point(3, 4)
  let v11: Bool = call $thunk_50()
  let v12: Dict = get_dict Show[Bool]
  let v13: Unit = call println(v12, v11)
  let_join v24(v22: Bool) =
    let v14: Dict = get_dict Show[Bool]
    let v23: Unit = call println(v14, v22)
    v23
  in
  let v15: Dict = get_dict Eq[Int]
  let v16: Dict = get_dict Hash[Point]
  let v17: Int = call hash(v16, v0)
  let v18: Dict = get_dict Hash[Point]
  let v19: Int = call hash(v18, v2)
  let v20: Bool = call eq(v15, v17, v19)
  let v21: Bool = not(v20)
  jump v24(v21)

fn $thunk_50() -> Bool =
  let_join v10(v9: Bool) =
    v9
  in
  let v3: Dict = get_dict Eq[Int]
  let v4: Dict = get_dict Hash[Point]
  let v5: Int = call hash(v4, v0)
  let v6: Dict = get_dict Hash[Point]
  let v7: Int = call hash(v6, v1)
  let v8: Bool = call eq(v3, v5, v7)
  jump v10(v8)
