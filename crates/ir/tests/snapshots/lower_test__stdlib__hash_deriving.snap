module stdlib__hash_deriving

struct Point { x: Int, y: Int }
declare eq: (Dict, g, g) -> Bool
declare hash: (Dict, g) -> Int
declare println: (Dict, m) -> Unit

fn main() -> Unit =
  let v0: ~Point = construct Point(1, 2)
  let v1: ~Point = construct Point(1, 2)
  let v2: ~Point = construct Point(3, 4)
  let_join v31(v19: Unit) =
    let_join v30(v28: Bool) =
      let v20: Dict = get_dict Show[Bool]
      let v29: Unit = call println(v20, v28)
      v29
    in
    let v21: Dict = get_dict Eq[Int]
    let v22: Dict = get_dict Hash[Point]
    let v23: Int = call hash(v22, v0)
    let v24: Dict = get_dict Hash[Point]
    let v25: Int = call hash(v24, v2)
    let v26: Bool = call eq(v21, v23, v25)
    let v27: Bool = not(v26)
    jump v30(v27)
  in
  let_join v18(v16: Bool) =
    let v9: Dict = get_dict Show[Bool]
    let v17: Unit = call println(v9, v16)
    jump v31(v17)
  in
  let v10: Dict = get_dict Eq[Int]
  let v11: Dict = get_dict Hash[Point]
  let v12: Int = call hash(v11, v0)
  let v13: Dict = get_dict Hash[Point]
  let v14: Int = call hash(v13, v1)
  let v15: Bool = call eq(v10, v12, v14)
  jump v18(v15)
