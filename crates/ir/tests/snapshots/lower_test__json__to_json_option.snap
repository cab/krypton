import core/peek/peek as peek(h): h
import core/list/last as last(List[t3]): Option[t3]
import core/list/sort_by as sort_by(List[y5], (y5) -> n5): List[y5]
import core/list/filter as filter(List[i1], (i1) -> Bool): List[i1]
import core/list/fold as fold(List[v1], x1, (x1, v1) -> x1): x1
import core/list/map as map(List[x], (x) -> z): List[z]
import core/vec/to_list as to_list(Vec[j7]): List[j7]
import core/io/println as println(m): Unit
import core/option/Some as Some(e): Option[e]
import core/option/None as None(): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
import core/list/Nil as Nil(): List[h]
import core/ordering/LT as LT(): Ordering
import core/ordering/EQ as EQ(): Ordering
import core/ordering/GT as GT(): Ordering
import core/option/Some as Some(g): Option[g]
import core/option/None as None(): Option[g]
import core/json/json_to_string as json_to_string(Json): String
import core/json/JNull as JNull(): Json
import core/json/JBool as JBool(Bool): Json
import core/json/JNum as JNum(Float): Json
import core/json/JStr as JStr(String): Json
import core/json/JArr as JArr(List[Json]): Json
import core/json/JObj as JObj(Map[String, Json]): Json
declare json_to_string: (Json) -> String
declare println: (m) -> Unit

fn main() -> Unit =
  let v1: ~Option[Int] = construct Option::None#1()
  let v0: ~Option[Int] = v1
  let v2: Dict[core/json.ToJson, Option[Int]] = get_dict core/json.ToJson[Option[Int]]
  let v3: Json = trait_call core/json.ToJson.to_json(v2, v0)
  let v4: String = call json_to_string(v3)
  let v5: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v6: Unit = call println(v5, v4)
  let v8: ~Option[Int] = construct Option::Some#0(42)
  let v9: Dict[core/json.ToJson, Option[Int]] = get_dict core/json.ToJson[Option[Int]]
  let v10: Json = trait_call core/json.ToJson.to_json(v9, v8)
  let v11: String = call json_to_string(v10)
  let v7: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v12: Unit = call println(v7, v11)
  v12
