module tuples__tuple5

declare println: (m) -> Unit

fn main() -> Unit =
  let v0: (~Int, ~Int, ~Int, ~Int, ~Int) = tuple(1, 2, 3, 4, 5)
  let v1: Int = tuple_project v0.0
  let v2: Int = tuple_project v0.1
  let v3: Int = tuple_project v0.2
  let v4: Int = tuple_project v0.3
  let v5: Int = tuple_project v0.4
  let v6: Int = add_int(v1, v2)
  let v7: Int = add_int(v6, v3)
  let v8: Int = add_int(v7, v4)
  let v9: Int = add_int(v8, v5)
  let v10: Unit = call println(v9)
  v10
