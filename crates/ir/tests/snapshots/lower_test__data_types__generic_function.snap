fn map_option(v0: Option[s9], v1: (s9) -> t9) -> Option[t9] =
  switch v0 {
    0 (v2: s9) ->
      let v3: t9 = call_closure v1(v2)
      let v4: ~Option[t9] = construct Option::Some#0(v3)
      v4
    1 ->
      let v5: ~Option[t9] = construct Option::None#1()
      v5
  }
