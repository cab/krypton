import core/vec/nth as nth(Vec[t6], Int): Option[t6]
declare nth: (Vec[t6], Int) -> Option[t6]
declare println: (o) -> Unit
declare split: (String, String) -> Vec[String]

fn main() -> Unit =
  let v0: Vec[String] = call split("hello world", " ")
  let v1: Option[String] = call nth(v0, 0)
  switch v1 {
    0 (v2: String) ->
      let v3: Dict[core/show.Show, String] = get_dict core/show.Show[String]
      let v4: Unit = call println(v3, v2)
      v4
    1 ->
      let v5: Dict[core/show.Show, String] = get_dict core/show.Show[String]
      let v6: Unit = call println(v5, "error")
      v6
  }
