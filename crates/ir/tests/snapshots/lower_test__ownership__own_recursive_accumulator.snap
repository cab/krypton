module ownership__own_recursive_accumulator

declare eq: (Dict, g, g) -> Bool

fn sum_to(v0: Int, v1: Int) -> Int =
  let_join v8(v4: Bool) =
    switch v4 {
      1 ->
        v1
      _ ->
        let v5: Int = sub_int(v0, 1)
        let v6: Int = add_int(v1, v0)
        let v7: Int = call sum_to(v5, v6)
        v7
    }
  in
  let v2: Dict = get_dict Eq[Int]
  let v3: Bool = call eq(v2, v0, 0)
  jump v8(v3)
