import core/option/None as None(): Option[g]
import core/json/JStr as JStr(String): Json
import core/json/JObj as JObj(Map[String, Json]): Json
import core/json/parse_json as parse_json(String): Result[String, Json]
import core/json/json_get as json_get(Json, String): Option[Json]
declare json_get: (Json, String) -> Option[Json]
declare parse_json: (String) -> Result[String, Json]
declare println: (Dict, m) -> Unit

fn main() -> Unit =
  let v0: Result[String, Json] = call parse_json("{"name":"alice"}")
  switch v0 {
    0 (v1: d) ->
      let v2: Option[Json] = call json_get(v1, "name")
      switch v2 {
        0 (v3: b) ->
          switch v3 {
            3 (v4: String) ->
              let v5: Dict = get_dict Show[String]
              let v6: Unit = call println(v5, v4)
              v6
            _ ->
              let v7: Dict = get_dict Show[String]
              let v8: Unit = call println(v7, "FAIL get")
              v8
          }
        _ ->
          let v9: Dict = get_dict Show[String]
          let v10: Unit = call println(v9, "FAIL get")
          v10
      }
    1 (v11: c) ->
      let v12: Dict = get_dict Show[String]
      let v13: Unit = call println(v12, v11)
      v13
  }
