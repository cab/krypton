module traits__trait_basic

struct Point { x: Int, y: Int }
instance core/eq.Eq[Point] { eq=Eq$$Point$$eq }
import core/peek/peek as peek(h): h
import core/list/last as last(List[u3]): Option[u3]
import core/list/sort_by as sort_by(List[z5], (z5) -> o5): List[z5]
import core/list/filter as filter(List[j1], (j1) -> Bool): List[j1]
import core/list/fold as fold(List[w1], y1, (y1, w1) -> y1): y1
import core/list/map as map(List[y], (y) -> a1): List[a1]
import core/vec/to_list as to_list(Vec[c8]): List[c8]
import core/io/println as println(o): Unit
import core/option/Some as Some(e): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]

fn main() -> Bool =
  let v1: ~Point = construct Point(1, 2)
  let v2: ~Point = construct Point(1, 2)
  let v0: Dict[core/eq.Eq, Point] = get_dict core/eq.Eq[Point]
  let v3: Bool = trait_call core/eq.Eq.eq(v0, v1, v2)
  v3

fn Eq$$Point$$eq(v4: Point, v5: Point) -> Bool =
  let_join v15(v10: Bool) =
    if v10 {
      let v11: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
      let v12: Int = project v4.1
      let v13: Int = project v5.1
      let v14: Bool = trait_call core/eq.Eq.eq(v11, v12, v13)
      v14
    } else {
      false
    }
  in
  let v6: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
  let v7: Int = project v4.0
  let v8: Int = project v5.0
  let v9: Bool = trait_call core/eq.Eq.eq(v6, v7, v8)
  jump v15(v9)
