module map_operations

; extern contains
; extern delete
; extern empty
; extern println
; extern put
; extern size

fn main() -> Unit =
  let v1: Map[String, Int] = call empty()
  let v2: Map[String, Int] = call put(v1, "a", 10)
  let v0: Map[String, Int] = call put(v2, "b", 11)
  let v3: Bool = call contains(v0, "a")
  let v4: Unit = call println(v3)
  let v5: Map[String, Int] = call delete(v0, "a")
  let v6: Bool = call contains(v5, "a")
  let v7: Unit = call println(v6)
  let v8: Int = call size(v0)
  let v9: Unit = call println(v8)
  v9
