import core/peek/peek as peek(h): h
import core/list/last as last(List[t3]): Option[t3]
import core/list/sort_by as sort_by(List[y5], (y5) -> n5): List[y5]
import core/list/filter as filter(List[i1], (i1) -> Bool): List[i1]
import core/list/fold as fold(List[v1], x1, (x1, v1) -> x1): x1
import core/list/map as map(List[x], (x) -> z): List[z]
import core/vec/to_list as to_list(Vec[j7]): List[j7]
import core/io/println as println(m): Unit
import core/option/Some as Some(e): Option[e]
import core/option/None as None(): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
import core/list/Nil as Nil(): List[h]
import core/ordering/LT as LT(): Ordering
import core/ordering/EQ as EQ(): Ordering
import core/ordering/GT as GT(): Ordering
import core/string/parse_int as parse_int(String): Option[Int]
import core/string/parse_float as parse_float(String): Option[Float]
declare parse_float: (String) -> Option[Float]
declare parse_int: (String) -> Option[Int]
declare println: (m) -> Unit

fn main() -> Unit =
  let v0: Option[Int] = call parse_int("42")
  let v1: Dict[core/show.Show, Option[Int]] = get_dict core/show.Show[Option[Int]]
  let v2: Unit = call println(v1, v0)
  let v3: Option[Int] = call parse_int("abc")
  let v4: Dict[core/show.Show, Option[Int]] = get_dict core/show.Show[Option[Int]]
  let v5: Unit = call println(v4, v3)
  let v6: Option[Float] = call parse_float("3.14")
  let v7: Dict[core/show.Show, Option[Float]] = get_dict core/show.Show[Option[Float]]
  let v8: Unit = call println(v7, v6)
  let v10: Option[Float] = call parse_float("xyz")
  let v9: Dict[core/show.Show, Option[Float]] = get_dict core/show.Show[Option[Float]]
  let v11: Unit = call println(v9, v10)
  v11
