import core/peek/peek as peek(h): h
import core/list/last as last(List[u3]): Option[u3]
import core/list/sort_by as sort_by(List[z5], (z5) -> o5): List[z5]
import core/list/filter as filter(List[j1], (j1) -> Bool): List[j1]
import core/list/fold as fold(List[w1], y1, (y1, w1) -> y1): y1
import core/list/map as map(List[y], (y) -> a1): List[a1]
import core/vec/to_list as to_list(Vec[c8]): List[c8]
import core/io/println as println(o): Unit
import core/option/Some as Some(e): Option[e]
import core/option/None as None(): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
import core/list/Nil as Nil(): List[h]
import core/ordering/LT as LT(): Ordering
import core/ordering/EQ as EQ(): Ordering
import core/ordering/GT as GT(): Ordering
import core/string/parse_int as parse_int(String): Option[Int]
import core/string/parse_float as parse_float(String): Option[Float]
declare parse_float: (String) -> Option[Float]
declare parse_int: (String) -> Option[Int]
declare println: (o) -> Unit

fn main() -> Unit =
  let v0: Option[Int] = call parse_int("42")
  let v1: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v2: Dict[core/show.Show, Option[Int]] = make_dict core/show.Show[Option[Int]](v1)
  let v3: Unit = call println(v2, v0)
  let v4: Option[Int] = call parse_int("abc")
  let v5: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v6: Dict[core/show.Show, Option[Int]] = make_dict core/show.Show[Option[Int]](v5)
  let v7: Unit = call println(v6, v4)
  let v8: Option[Float] = call parse_float("3.14")
  let v9: Dict[core/show.Show, Float] = get_dict core/show.Show[Float]
  let v10: Dict[core/show.Show, Option[Float]] = make_dict core/show.Show[Option[Float]](v9)
  let v11: Unit = call println(v10, v8)
  let v14: Option[Float] = call parse_float("xyz")
  let v12: Dict[core/show.Show, Float] = get_dict core/show.Show[Float]
  let v13: Dict[core/show.Show, Option[Float]] = make_dict core/show.Show[Option[Float]](v12)
  let v15: Unit = call println(v13, v14)
  v15
