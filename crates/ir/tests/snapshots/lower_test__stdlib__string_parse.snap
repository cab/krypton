module stdlib__string_parse

; extern parse_float
; extern parse_int
; extern println

fn main() -> Unit =
  let v0: Option[Int] = call parse_int("42")
  let v1: Dict = get_dict Show[Option[Int]]
  let v2: Unit = call println(v1, v0)
  let v3: Option[Int] = call parse_int("abc")
  let v4: Dict = get_dict Show[Option[Int]]
  let v5: Unit = call println(v4, v3)
  let v6: Option[Float] = call parse_float("3.14")
  let v7: Dict = get_dict Show[Option[Float]]
  let v8: Unit = call println(v7, v6)
  let v9: Option[Float] = call parse_float("xyz")
  let v10: Dict = get_dict Show[Option[Float]]
  let v11: Unit = call println(v10, v9)
  v11
