import core/result/Ok as Ok(e) -> Result[d, e]
import core/result/Err as Err(d) -> Result[d, e]
import core/list/Cons as Cons(f, List[f]) -> List[f]
declare abs: (Int) -> Int
declare println: (h) -> Unit

fn main() -> Unit =
  let v1: Int = neg_int(42)
  let v2: Int = call abs(v1)
  let v3: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v4: String = trait_call core/show.Show.show(v3, v2)
  let v0: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v5: Unit = call println(v0, v4)
  v5
