module stdlib__vec_get

declare nth: (Vec[o6], Int) -> Option[o6]
declare println: (m) -> Unit

fn main() -> Unit =
  let v0: Vec[Int] = make_vec(1, 2, 3)
  let v1: Option[Int] = call nth(v0, 0)
  switch v1 {
    0 (v2: d) ->
      let v3: Unit = call println(v2)
      v3
    1 ->
      let v4: Unit = call println(0)
      v4
  }
