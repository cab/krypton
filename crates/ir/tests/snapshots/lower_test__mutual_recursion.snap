expression: ir_module.to_string()
---
module mutual_recursion

fn is_even(v0: Int) -> Bool =
  let v1: Bool = eq_int(v0, 0)
  switch v1 {
    1 ->
      true
    _ ->
      let v2: Int = sub_int(v0, 1)
      let v3: Bool = call is_odd(v2)
      v3
  }

fn is_odd(v4: Int) -> Bool =
  let v5: Bool = eq_int(v4, 0)
  switch v5 {
    1 ->
      false
    _ ->
      let v6: Int = sub_int(v4, 1)
      let v7: Bool = call is_even(v6)
      v7
  }
