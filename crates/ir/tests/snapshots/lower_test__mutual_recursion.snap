module mutual_recursion

type Result[e, f] = Ok#0(b) | Err#1(a)
type Option[g] = Some#0(c) | None#1
type List[h] = Cons#0(d, List[d]) | Nil#1
type Ordering = LT#0 | EQ#1 | GT#2

fn f0 is_even(v0: Int) -> Bool =
  let v1: Bool = eq_int(v0, 0)
  switch v1 {
    1 ->
      true
    _ ->
      let v2: Int = sub_int(v0, 1)
      let v3: Bool = call f1(v2)
      v3
  }

fn f1 is_odd(v4: Int) -> Bool =
  let v5: Bool = eq_int(v4, 0)
  switch v5 {
    1 ->
      false
    _ ->
      let v6: Int = sub_int(v4, 1)
      let v7: Bool = call f0(v6)
      v7
  }
