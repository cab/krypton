fn is_even(v0: Int) -> Bool =
  let_join v6(v3: Bool) =
    if v3 {
      true
    } else {
      let v4: Int = sub_int(v0, 1)
      let v5: Bool = call is_odd(v4)
      v5
    }
  in
  let v1: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
  let v2: Bool = trait_call core/eq.Eq.eq(v1, v0, 0)
  jump v6(v2)

fn is_odd(v7: Int) -> Bool =
  let_join v13(v10: Bool) =
    if v10 {
      false
    } else {
      let v11: Int = sub_int(v7, 1)
      let v12: Bool = call is_even(v11)
      v12
    }
  in
  let v8: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
  let v9: Bool = trait_call core/eq.Eq.eq(v8, v7, 0)
  jump v13(v9)
