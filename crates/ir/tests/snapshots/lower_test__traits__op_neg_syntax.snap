module traits__op_neg_syntax

struct Vec2 { x: Int, y: Int }
declare Vec2: (Int, Int) -> Vec2
declare neg: (Dict, g) -> g
declare println: (m) -> Unit

fn main() -> Unit =
  let v0: ~Vec2 = call Vec2(3, 5)
  let_join v10(v8: Int) =
    let v9: Unit = call println(v8)
    v9
  in
  let_join v7(v5: Vec2) =
    let v6: Int = project v5.0
    jump v10(v6)
  in
  let v3: Dict = get_dict Neg[Vec2]
  let v4: Vec2 = call neg(v3, v0)
  jump v7(v4)
