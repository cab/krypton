declare println: (k) -> Unit

fn main() -> Unit =
  let v0: ~Vec2 = construct Vec2(3, 5)
  let_join v11(v9: Int) =
    let v1: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
    let v10: Unit = call println(v1, v9)
    v10
  in
  let_join v8(v6: Vec2) =
    let v7: Int = project v6.0
    jump v11(v7)
  in
  let v4: Dict[core/neg.Neg, Vec2] = get_dict core/neg.Neg[Vec2]
  let v5: Vec2 = trait_call core/neg.Neg.neg(v4, v0)
  jump v8(v5)

fn Neg$$Vec2$$neg(v12: Vec2) -> ~Vec2 =
  let v13: Int = project v12.0
  let v14: Int = sub_int(0, v13)
  let v15: Int = project v12.1
  let v16: Int = sub_int(0, v15)
  let v17: ~Vec2 = construct Vec2(v14, v16)
  v17
