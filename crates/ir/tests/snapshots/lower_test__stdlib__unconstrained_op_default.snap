module stdlib__unconstrained_op_default

declare println: (Dict, m) -> Unit
declare show: (Dict, g) -> String

fn add_ints(v0: Int, v1: Int) -> Int =
  let v2: Int = add_int(v0, v1)
  v2

fn main() -> Unit =
  let v4: Int = call add_ints(1, 2)
  let v5: Dict = get_dict Show[Int]
  let v6: String = call show(v5, v4)
  let v3: Dict = get_dict Show[String]
  let v7: Unit = call println(v3, v6)
