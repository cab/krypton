module json__json_get_nonobject

declare json_get: (Json, String) -> Option[Json]
declare println: (Dict, m) -> Unit

fn main() -> Unit =
  let v0: ~Json = construct Json::JNum#2(1.0)
  let v1: Option[Json] = call json_get(v0, "x")
  switch v1 {
    1 ->
      let v2: Dict = get_dict Show[String]
      let v3: Unit = call println(v2, "None")
      v3
    0 (v4: b) ->
      let v5: Dict = get_dict Show[String]
      let v6: Unit = call println(v5, "FAIL")
      v6
  }
