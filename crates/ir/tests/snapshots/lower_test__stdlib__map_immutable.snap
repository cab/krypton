module stdlib__map_immutable

declare contains: (Dict, Dict, Map[j10, k10], j10) -> Bool
declare empty: () -> Map[n8, o8]
declare println: (Dict, m) -> Unit
declare put: (Dict, Dict, Map[s8, t8], s8, t8) -> Map[s8, t8]

fn main() -> Unit =
  let v0: Map[x10, y10] = call empty()
  let v2: Dict = get_dict Eq[String]
  let v3: Dict = get_dict Hash[String]
  let v1: Map[String, Int] = call put(v2, v3, v0, "x", 1)
  let v4: Dict = get_dict Eq[String]
  let v5: Dict = get_dict Hash[String]
  let v6: Bool = call contains(v4, v5, v0, "x")
  let v7: Dict = get_dict Show[Bool]
  let v8: Unit = call println(v7, v6)
  let v9: Dict = get_dict Eq[String]
  let v10: Dict = get_dict Hash[String]
  let v11: Bool = call contains(v9, v10, v1, "x")
  let v12: Dict = get_dict Show[Bool]
  let v13: Unit = call println(v12, v11)
  v13
