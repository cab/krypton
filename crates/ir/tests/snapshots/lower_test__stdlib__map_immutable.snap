import core/map/empty as empty(): Map[m10, n10]
import core/map/put as put(Map[q10, r10], q10, r10): Map[q10, r10]
import core/map/contains as contains(Map[d12, e12], d12): Bool
declare contains: (Map[d12, e12], d12) -> Bool
declare empty: () -> Map[m10, n10]
declare println: (o) -> Unit
declare put: (Map[q10, r10], q10, r10) -> Map[q10, r10]

fn main() -> Unit =
  let v0: Map[r12, s12] = call empty()
  let v2: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v3: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v1: Map[String, Int] = call put(v2, v3, v0, "x", 1)
  let v4: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v5: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v6: Bool = call contains(v4, v5, v0, "x")
  let v7: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
  let v8: Unit = call println(v7, v6)
  let v10: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v11: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v12: Bool = call contains(v10, v11, v1, "x")
  let v9: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
  let v13: Unit = call println(v9, v12)
  v13
