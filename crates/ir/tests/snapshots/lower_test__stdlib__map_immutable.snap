module stdlib__map_immutable

declare contains: (Dict, Dict, Map[n10, o10], n10) -> Bool
declare empty: () -> Map[r8, s8]
declare println: (Dict, m) -> Unit
declare put: (Dict, Dict, Map[w8, x8], w8, x8) -> Map[w8, x8]

fn main() -> Unit =
  let v0: Map[b11, c11] = call empty()
  let v2: Dict = get_dict Eq[String]
  let v3: Dict = get_dict Hash[String]
  let v1: Map[String, Int] = call put(v2, v3, v0, "x", 1)
  let v4: Dict = get_dict Eq[String]
  let v5: Dict = get_dict Hash[String]
  let v6: Bool = call contains(v4, v5, v0, "x")
  let v7: Dict = get_dict Show[Bool]
  let v8: Unit = call println(v7, v6)
  let v10: Dict = get_dict Eq[String]
  let v11: Dict = get_dict Hash[String]
  let v12: Bool = call contains(v10, v11, v1, "x")
  let v9: Dict = get_dict Show[Bool]
  let v13: Unit = call println(v9, v12)
  v13
