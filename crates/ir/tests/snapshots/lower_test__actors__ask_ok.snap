module actors__ask_ok

type Msg = Get#0(Ref[Int])
declare Get: (Ref[Int]) -> Msg
declare ask: (Ref[l10], (Ref[m10]) -> l10, Int) -> Result[Timeout, m10]
declare println: (m) -> Unit
declare receive: (Mailbox[e9]) -> e9
declare send: (Ref[t8], t8) -> Unit
declare spawn: ((Mailbox[n8]) -> Unit) -> Ref[n8]

fn value_actor(v0: Mailbox[Msg]) -> Unit =
  let v1: Msg = call receive(v0)
  switch v1 {
    0 (v2: Ref[Int]) ->
      let v3: Unit = call send(v2, 42)
      v3
  }

fn main() -> Unit =
  let v5: (Mailbox[Msg]) -> Unit = make_closure(value_actor, [])
  let v4: Ref[Msg] = call spawn(v5)
  let v6: (Ref[Int]) -> Msg = make_closure(Get, [])
  let v7: Result[Timeout, Int] = call ask(v4, v6, 5000)
  switch v7 {
    0 (v8: d) ->
      let v9: Unit = call println(v8)
      v9
    1 (v10: c) ->
      switch v10 {
        0 ->
          let v11: Unit = call println("timeout")
          v11
      }
  }
