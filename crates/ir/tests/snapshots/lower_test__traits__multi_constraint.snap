fn eq_and_show(v0: Dict[core/eq.Eq, w7], v1: Dict[core/show.Show, w7], v2: w7, v3: w7) -> String =
  let v4: Bool = trait_call core/eq.Eq.eq(v0, v2, v3)
  if v4 {
    let v5: String = trait_call core/show.Show.show(v1, v2)
    v5
  } else {
    "not equal"
  }

fn main() -> Unit =
  let_join v15(v13: Bool) =
    let v14: Unit = call println(v13)
    v14
  in
  let v6: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v7: ~Box = call Box(1)
  let v8: ~Box = call Box(1)
  let v9: Dict[core/eq.Eq, Box] = get_dict core/eq.Eq[Box]
  let v10: Dict[core/show.Show, Box] = get_dict core/show.Show[Box]
  let v11: String = call eq_and_show(v9, v10, v7, v8)
  let v12: Bool = trait_call core/eq.Eq.eq(v6, v11, "Box")
  jump v15(v12)

fn Eq$$Box$$eq(v16: Box, v17: Box) -> Bool =
  let v18: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
  let v19: Int = project v16.0
  let v20: Int = project v17.0
  let v21: Bool = trait_call core/eq.Eq.eq(v18, v19, v20)
  v21

fn Show$$Box$$show(v22: Box) -> ~String =
