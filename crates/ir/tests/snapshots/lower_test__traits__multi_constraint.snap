fn eq_and_show(v0: Dict[core/eq.Eq, o8], v1: Dict[core/show.Show, o8], v2: o8, v3: o8) -> String =
  let v4: Bool = trait_call core/eq.Eq.eq(v0, v2, v3)
  if v4 {
    let v5: String = trait_call core/show.Show.show(v1, v2)
    v5
  } else {
    "not equal"
  }

