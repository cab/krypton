module traits__multi_constraint

struct Box { val: Int }
declare Box: (Int) -> Box
declare eq: (Dict, g, g) -> Bool
declare println: (m) -> Unit
declare show: (Dict, g) -> String

fn eq_and_show(v0: Dict, v1: Dict, v2: t7, v3: t7) -> String =
  let v4: Bool = call eq(v0, v2, v3)
  switch v4 {
    1 ->
      let v5: String = call show(v1, v2)
      v5
    _ ->
      "not equal"
  }

fn main() -> Unit =
  let v6: ~Box = call Box(1)
  let v7: ~Box = call Box(1)
  let v8: Dict = get_dict Eq[Box]
  let v9: Dict = get_dict Show[Box]
  let v10: String = call eq_and_show(v8, v9, v6, v7)
  let v11: Bool = eq_string(v10, "Box")
  let v12: Unit = call println(v11)
  v12
