import core/list/map as map(List[y], (y) -> a1): List[a1]
import core/vec/to_list as to_list(Vec[y8]): List[y8]
import core/io/println as println(s): Unit
import core/option/Some as Some(e): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
declare println: (s) -> Unit

fn eq_and_show(v0: Dict[core/eq.Eq, k9], v1: Dict[core/show.Show, k9], v2: k9, v3: k9) -> String =
  let v4: Bool = trait_call core/eq.Eq.eq(v0, v2, v3)
  if v4 {
    let v5: String = trait_call core/show.Show.show(v1, v2)
    v5
  } else {
    "not equal"
  }

fn main() -> Unit =
  let_join v16(v14: Bool) =
    let v6: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
    let v15: Unit = call println(v6, v14)
    v15
  in
  let v7: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v8: ~Box = construct Box(1)
  let v9: ~Box = construct Box(1)
  let v10: Dict[core/eq.Eq, Box] = get_dict core/eq.Eq[Box]
  let v11: Dict[core/show.Show, Box] = get_dict core/show.Show[Box]
  let v12: String = call eq_and_show(v10, v11, v8, v9)
  let v13: Bool = trait_call core/eq.Eq.eq(v7, v12, "Box")
  jump v16(v13)

fn Eq$$Box$$eq(v17: Box, v18: Box) -> Bool =
  let v19: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
  let v20: Int = project v17.0
  let v21: Int = project v18.0
  let v22: Bool = trait_call core/eq.Eq.eq(v19, v20, v21)
  v22

fn Show$$Box$$show(v23: Box) -> ~String =
  "Box"
