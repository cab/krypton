module traits__multi_constraint

struct Box { val: Int }
declare Box: (Int) -> Box
declare eq: (Dict, g, g) -> Bool
declare println: (m) -> Unit
declare show: (Dict, g) -> String

fn eq_and_show(v0: Dict, v1: Dict, v2: t7, v3: t7) -> String =
  let v4: Bool = call eq(v0, v2, v3)
  switch v4 {
    1 ->
      let v5: String = call show(v1, v2)
      v5
    _ ->
      "not equal"
  }

fn main() -> Unit =
  let_join v15(v13: Bool) =
    let v14: Unit = call println(v13)
    v14
  in
  let v6: Dict = get_dict Eq[String]
  let v7: ~Box = call Box(1)
  let v8: ~Box = call Box(1)
  let v9: Dict = get_dict Eq[Box]
  let v10: Dict = get_dict Show[Box]
  let v11: String = call eq_and_show(v9, v10, v7, v8)
  let v12: Bool = call eq(v6, v11, "Box")
  jump v15(v12)
