  let v6: Dict[Eq, String] = get_dict Eq[String]
  let v7: ~Box = call Box(1)
  let v8: ~Box = call Box(1)
  let v9: Dict[Eq, Box] = get_dict Eq[Box]
  let v10: Dict[Show, Box] = get_dict Show[Box]
