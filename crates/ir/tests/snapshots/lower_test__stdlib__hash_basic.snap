module stdlib__hash_basic

declare eq: (Dict, g, g) -> Bool
declare hash: (Dict, g) -> Int
declare println: (Dict, m) -> Unit

fn main() -> Unit =
  let v1: Dict = get_dict Hash[Int]
  let v0: Int = call hash(v1, 42)
  let_join v9(v7: Bool) =
    let v2: Dict = get_dict Show[Bool]
    let v8: Unit = call println(v2, v7)
    v8
  in
  let v3: Dict = get_dict Eq[Int]
  let v4: Dict = get_dict Hash[Int]
  let v5: Int = call hash(v4, 42)
  let v6: Bool = call eq(v3, v0, v5)
  jump v9(v6)
