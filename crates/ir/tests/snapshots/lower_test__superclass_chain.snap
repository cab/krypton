module superclass_chain

struct Num { n: Int }
; extern Num
; extern lt
; extern println

fn is_less(v0: t7, v1: t7) -> Bool =
  let v2: Bool = call lt(v0, v1)
  v2

fn main() -> Unit =
  let v3: ~Num = call Num(1)
  let v4: ~Num = call Num(2)
  let v5: Bool = call is_less(v3, v4)
  let v6: Unit = call println(v5)
  v6
