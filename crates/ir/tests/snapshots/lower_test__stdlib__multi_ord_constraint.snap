fn both_less(v0: Dict[core/ord.Ord, o8], v1: Dict[core/ord.Ord, p8], v2: o8, v3: o8, v4: p8, v5: p8) -> Bool =
  let_join v13(v6: Bool) =
    let_join v12(v8: Bool) =
      let_join v11(v10: Bool) =
        if v10 {
          v8
        } else {
