module json__to_json_string

declare json_to_string: (Json) -> String
declare println: (Dict, m) -> Unit
declare to_json: (Dict, i14) -> Json

fn main() -> Unit =
  let v0: Dict = get_dict ToJson[String]
  let v1: Json = call to_json(v0, "hello")
  let v2: String = call json_to_string(v1)
  let v3: Dict = get_dict Show[String]
  let v4: Unit = call println(v3, v2)
  v4
