declare println: (m) -> Unit

fn first(v0: Int) -> Option[Int] =
  let v1: ~Option[Int] = construct Option::Some#0(v0)
  v1

fn second(v2: a8) -> Option[Int] =
  let v3: ~Option[Int] = construct Option::None#1()
  v3

fn process(v4: Int) -> Option[Int] =
  let_join v5(v6: Option[Int]) =
    v6
  in
  let_join v17(v7: Int) =
    let_join v16(v11: Int) =
      let v15: ~Option[Int] = construct Option::Some#0(v11)
      v15
    in
    let v12: Option[Int] = call second(v7)
    switch v12 {
      0 (v13: Int) ->
        jump v16(v13)
      1 ->
        let v14: Option[Int] = construct Option::None#1()
        jump v5(v14)
    }
  in
  let v8: Option[Int] = call first(v4)
  switch v8 {
    0 (v9: Int) ->
      jump v17(v9)
    1 ->
      let v10: Option[Int] = construct Option::None#1()
      jump v5(v10)
  }

fn main() -> Unit =
  let v18: Option[Int] = call process(21)
  switch v18 {
    0 (v19: Int) ->
      let v20: Unit = call println(v19)
      v20
    1 ->
      let v21: Unit = call println(0)
      v21
  }
