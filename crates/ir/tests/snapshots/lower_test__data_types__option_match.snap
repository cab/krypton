module data_types__option_match

type Option[a] = Some#0(a) | None#1
declare println: (m) -> Unit

fn unwrap_or(v0: Option[w7], v1: w7) -> w7 =
  switch v0 {
    0 (v2: a) ->
      v2
    1 ->
      v1
  }

fn main() -> Unit =
  let v3: ~Option[Int] = construct Option::Some#0(42)
  let v4: Int = call unwrap_or(v3, 0)
  let v5: Unit = call println(v4)
