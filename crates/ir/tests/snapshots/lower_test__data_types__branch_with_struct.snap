module data_types__branch_with_struct

struct Wrapper { value: Int }
; extern Wrapper
; extern println

fn pick(v0: Int) -> Wrapper =
  let v1: Bool = gt_int(v0, 0)
  switch v1 {
    1 ->
      let v2: ~Wrapper = call Wrapper(100)
      v2
    _ ->
      let v3: ~Wrapper = call Wrapper(42)
      v3
  }

fn main() -> Unit =
  let v4: Wrapper = call pick(1)
  let v6: Int = neg_int(1)
  let v5: Wrapper = call pick(v6)
  let v7: Int = project v4.0
  let v8: Unit = call println(v7)
  let v9: Int = project v5.0
  let v10: Unit = call println(v9)
  v10
