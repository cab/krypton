fn pick(v0: Int) -> Wrapper =
  let_join v6(v3: Bool) =
    if v3 {
      let v4: ~Wrapper = construct Wrapper(100)
      v4
    } else {
      let v5: ~Wrapper = construct Wrapper(42)
