declare println: (s) -> Unit

fn pick(v0: Int) -> Wrapper =
  let_join v6(v3: Bool) =
    if v3 {
      let v4: ~Wrapper = construct Wrapper(100)
      v4
    } else {
      let v5: ~Wrapper = construct Wrapper(42)
      v5
    }
  in
  let v1: Dict[core/ord.Ord, Int] = get_dict core/ord.Ord[Int]
  let v2: Bool = trait_call core/ord.Ord.lt(v1, 0, v0)
  jump v6(v2)

fn main() -> Unit =
  let v7: Wrapper = call pick(1)
  let v9: Int = neg_int(1)
  let v8: Wrapper = call pick(v9)
  let v10: Int = project v7.0
  let v11: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
