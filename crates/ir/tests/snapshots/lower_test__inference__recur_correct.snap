module inference__recur_correct

fn countdown(v0: Int) -> Int =
  let_join v1(v2: Int) =
    let v3: Bool = eq_int(v2, 0)
    switch v3 {
      1 ->
        0
      _ ->
        let v4: Int = sub_int(v2, 1)
        jump v1(v4)
    }
  in
  jump v1(v0)
