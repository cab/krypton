module exhaustiveness__match_bool_exhaustive

type Pair = MkPair#0(Bool, Bool)

fn test(v0: Pair) -> Int =
  switch v0 {
    0 (v1: Bool, v2: Bool) ->
      let v6: Bool = eq_int(v1, true)
      switch v6 {
        1 ->
          1
        _ ->
          let v5: Bool = eq_int(v1, false)
          switch v5 {
            1 ->
              let v4: Bool = eq_int(v2, true)
              switch v4 {
                1 ->
                  2
                _ ->
                  let v3: Bool = eq_int(v2, false)
                  switch v3 {
                    1 ->
                      3
                    _ ->
                      ()
                  }
              }
            _ ->
              ()
          }
      }
  }
