module derive_show_record

struct Point { x: Int, y: Int }
; extern Point
; extern println
; extern show

fn main() -> Unit =
  let v0: ~Point = call Point(1, 2)
  let v1: String = call show(v0)
  let v2: Unit = call println(v1)
  v2
