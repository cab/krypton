module traits__trait_eq_codegen

struct Point { x: Int, y: Int }
; extern Point
; extern eq
; extern println

fn main() -> Unit =
  let v0: ~Point = call Point(1, 2)
  let v1: ~Point = call Point(1, 2)
  let v2: Dict = get_dict Eq[Point]
  let v3: Bool = call eq(v2, v0, v1)
  let v4: Unit = call println(v3)
  v4
