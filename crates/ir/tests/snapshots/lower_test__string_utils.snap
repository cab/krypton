module string_utils

; extern char_at
; extern contains
; extern ends_with
; extern index_of
; extern join
; extern println
; extern replace
; extern starts_with
; extern to_lower
; extern to_upper

fn main() -> Unit =
  let v0: Bool = call contains("hello world", "world")
  let v1: Unit = call println(v0)
  let v2: Bool = call contains("hello world", "xyz")
  let v3: Unit = call println(v2)
  let v4: Bool = call starts_with("hello world", "hello")
  let v5: Unit = call println(v4)
  let v6: Bool = call ends_with("hello world", "world")
  let v7: Unit = call println(v6)
  let v8: Bool = call ends_with("hello world", "hello")
  let v9: Unit = call println(v8)
  let v10: String = call to_lower("Hello World")
  let v11: Unit = call println(v10)
  let v12: String = call to_upper("hello world")
  let v13: Unit = call println(v12)
  let v14: String = call replace("hello world", "world", "earth")
  let v15: Unit = call println(v14)
  let v16: Option[Int] = call index_of("hello world", "world")
  let v17: Unit = call println(v16)
  let v18: Option[Int] = call index_of("hello world", "xyz")
  let v19: Unit = call println(v18)
  let v21: ~List[String] = construct List::Nil#1()
  let v22: ~List[String] = construct List::Cons#0("world", v21)
  let v20: ~List[String] = construct List::Cons#0("hello", v22)
  let v23: String = call join(v20, ", ")
  let v24: Unit = call println(v23)
  let v25: Option[String] = call char_at("hello", 1)
  let v26: Unit = call println(v25)
  let v27: Option[String] = call char_at("hello", 10)
  let v28: Unit = call println(v27)
  v28
