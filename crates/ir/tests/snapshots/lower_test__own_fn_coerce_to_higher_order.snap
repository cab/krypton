module own_fn_coerce_to_higher_order

fn apply(v0: ~(r7) -> v7, v1: r7) -> v7 =
  let v2: v7 = call_closure v0(v1)
  v2

fn double(v3: Int) -> Int =
  let v4: Int = mul_int(v3, 2)
  v4

fn test() -> Int =
  let v5: (Int) -> Int = make_closure(double, [])
  let v6: Int = call apply(v5, 21)
  v6
