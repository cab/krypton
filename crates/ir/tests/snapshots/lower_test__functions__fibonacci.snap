declare println: (h) -> Unit

fn fibonacci(v0: Int) -> Int =
  let_join v10(v4: Bool) =
    if v4 {
      v0
    } else {
      let v5: Int = sub_int(v0, 1)
      let v6: Int = call fibonacci(v5)
      let v7: Int = sub_int(v0, 2)
      let v8: Int = call fibonacci(v7)
      let v9: Int = add_int(v6, v8)
      v9
    }
  in
  let v1: Dict[core/ord.Ord, Int] = get_dict core/ord.Ord[Int]
  let v2: Bool = trait_call core/ord.Ord.lt(v1, 1, v0)
  let v3: Bool = not(v2)
  jump v10(v3)

fn main() -> Unit =
  let v12: Int = call fibonacci(10)
  let v11: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v13: Unit = call println(v11, v12)
  v13
