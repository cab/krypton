module stdlib__map_operations

declare contains: (Dict, Dict, Map[k10, l10], k10) -> Bool
declare delete: (Dict, Dict, Map[b10, c10], b10) -> Map[b10, c10]
declare empty: () -> Map[o8, p8]
declare println: (Dict, m) -> Unit
declare put: (Dict, Dict, Map[t8, u8], t8, u8) -> Map[t8, u8]
declare size: (Map[g13, h13]) -> Int

fn main() -> Unit =
  let v1: Map[String, Int] = call empty()
  let v2: Dict = get_dict Eq[String]
  let v3: Dict = get_dict Hash[String]
  let v4: Map[String, Int] = call put(v2, v3, v1, "a", 10)
  let v5: Dict = get_dict Eq[String]
  let v6: Dict = get_dict Hash[String]
  let v0: Map[String, Int] = call put(v5, v6, v4, "b", 11)
  let v7: Dict = get_dict Eq[String]
  let v8: Dict = get_dict Hash[String]
  let v9: Bool = call contains(v7, v8, v0, "a")
  let v10: Dict = get_dict Show[Bool]
  let v11: Unit = call println(v10, v9)
  let v13: Dict = get_dict Eq[String]
  let v14: Dict = get_dict Hash[String]
  let v12: Map[String, Int] = call delete(v13, v14, v0, "a")
  let v15: Dict = get_dict Eq[String]
  let v16: Dict = get_dict Hash[String]
  let v17: Bool = call contains(v15, v16, v12, "a")
  let v18: Dict = get_dict Show[Bool]
  let v19: Unit = call println(v18, v17)
  let v21: Int = call size(v0)
  let v20: Dict = get_dict Show[Int]
  let v22: Unit = call println(v20, v21)
  v22
