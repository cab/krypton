import core/map/empty as empty() -> Map[e9, f9]
import core/map/put as put(Map[i9, j9], i9, j9) -> Map[i9, j9]
import core/map/delete as delete(Map[z9, a10], z9) -> Map[z9, a10]
import core/map/contains as contains(Map[h10, i10], h10) -> Bool
import core/map/size as size(Map[d13, e13]) -> Int
declare contains: (Map[h10, i10], h10) -> Bool
declare delete: (Map[z9, a10], z9) -> Map[z9, a10]
declare empty: () -> Map[e9, f9]
declare println: (k) -> Unit
declare put: (Map[i9, j9], i9, j9) -> Map[i9, j9]
declare size: (Map[d13, e13]) -> Int

fn main() -> Unit =
  let v1: Map[String, Int] = call empty()
  let v2: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v3: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v4: Map[String, Int] = call put(v2, v3, v1, "a", 10)
  let v5: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v6: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v0: Map[String, Int] = call put(v5, v6, v4, "b", 11)
  let v7: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v8: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v9: Bool = call contains(v7, v8, v0, "a")
  let v10: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
  let v11: Unit = call println(v10, v9)
  let v13: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v14: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v12: Map[String, Int] = call delete(v13, v14, v0, "a")
  let v15: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v16: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v17: Bool = call contains(v15, v16, v12, "a")
  let v18: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
  let v19: Unit = call println(v18, v17)
  let v21: Int = call size(v0)
  let v20: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v22: Unit = call println(v20, v21)
  v22
