module multi_constraint

struct Box { val: Int }
; extern Box
; extern eq
; extern println
; extern show

fn eq_and_show(v0: t7, v1: t7) -> String =
  let v2: Bool = call eq(v0, v1)
  switch v2 {
    1 ->
      let v3: String = call show(v0)
      v3
    _ ->
      "not equal"
  }

fn main() -> Unit =
  let v4: ~Box = call Box(1)
  let v5: ~Box = call Box(1)
  let v6: String = call eq_and_show(v4, v5)
  let v7: Bool = eq_string(v6, "Box")
  let v8: Unit = call println(v7)
  v8
