fn is_less(v0: Dict[core/ord.Ord, o8], v1: o8, v2: o8) -> Bool =
  let v3: Bool = trait_call core/ord.Ord.lt(v0, v1, v2)
  v3

fn main() -> Unit =
  let v5: ~Num = construct Num(1)
  let v6: ~Num = construct Num(2)
  let v7: Dict[core/ord.Ord, Num] = get_dict core/ord.Ord[Num]
