module modules__use_transitive_trait

declare println: (Dict, m) -> Unit
declare render: (Dict, s7) -> String

fn main() -> Unit =
  let v1: ~Msg = construct Msg::MkMsg#0("hi")
  let v2: Dict = get_dict Render[Msg]
  let v3: String = call render(v2, v1)
  let v0: Dict = get_dict Show[String]
  let v4: Unit = call println(v0, v3)
  v4
