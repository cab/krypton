module functions__recur_sum

declare eq: (Dict, g, g) -> Bool
declare println: (m) -> Unit

fn sum(v0: Int, v1: Int) -> Int =
  let_join v2(v3: Int, v4: Int) =
    let_join v10(v7: Bool) =
      switch v7 {
        1 ->
          v4
        _ ->
          let v8: Int = sub_int(v3, 1)
          let v9: Int = add_int(v4, v3)
          jump v2(v8, v9)
      }
    in
    let v5: Dict = get_dict Eq[Int]
    let v6: Bool = call eq(v5, v3, 0)
    jump v10(v6)
  in
  jump v2(v0, v1)

fn main() -> Unit =
  let v11: Int = call sum(100, 0)
  let v12: Unit = call println(v11)
  v12
