module constrained_fn_ref_type_app

; extern println
; extern show

fn show_it(v0: r7) -> String =
  let v1: String = call show(v0)
  v1

fn main() -> Unit =
  let v2: (String) -> String = make_closure(show_it, [])
  let v3: String = call_closure v2("hello")
  let v4: Bool = eq_string(v3, "hello")
  let v5: Unit = call println(v4)
  v5
