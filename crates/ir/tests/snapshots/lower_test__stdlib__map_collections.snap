module stdlib__map_collections

declare empty: () -> Map[r8, s8]
declare from_list: (Dict, Dict, List[(c13, d13)]) -> Map[c13, d13]
declare merge: (Dict, Dict, Map[p13, q13], Map[p13, q13]) -> Map[p13, q13]
declare println: (Dict, m) -> Unit
declare put: (Dict, Dict, Map[w8, x8], w8, x8) -> Map[w8, x8]
declare size: (Map[j13, k13]) -> Int

fn main() -> Unit =
  let v1: Map[String, Int] = call empty()
  let v2: Dict = get_dict Eq[String]
  let v3: Dict = get_dict Hash[String]
  let v4: Map[String, Int] = call put(v2, v3, v1, "a", 1)
  let v5: Dict = get_dict Eq[String]
  let v6: Dict = get_dict Hash[String]
  let v0: Map[String, Int] = call put(v5, v6, v4, "b", 2)
  let v8: Map[String, Int] = call empty()
  let v9: Dict = get_dict Eq[String]
  let v10: Dict = get_dict Hash[String]
  let v7: Map[String, Int] = call put(v9, v10, v8, "c", 3)
  let v12: Dict = get_dict Eq[String]
  let v13: Dict = get_dict Hash[String]
  let v11: Map[String, Int] = call merge(v12, v13, v0, v7)
  let v14: Int = call size(v11)
  let v15: Dict = get_dict Show[Int]
  let v16: Unit = call println(v15, v14)
  let v18: (~String, ~Int) = tuple("x", 10)
  let v19: (~String, ~Int) = tuple("y", 20)
  let v20: (~String, ~Int) = tuple("z", 30)
  let v21: ~List[(~String, ~Int)] = construct List::Nil#1()
  let v22: ~List[(~String, ~Int)] = construct List::Cons#0(v20, v21)
  let v23: ~List[(~String, ~Int)] = construct List::Cons#0(v19, v22)
  let v24: ~List[(~String, ~Int)] = construct List::Cons#0(v18, v23)
  let v25: Dict = get_dict Eq[c13]
  let v26: Dict = get_dict Hash[c13]
  let v17: Map[String, Int] = call from_list(v25, v26, v24)
  let v28: Int = call size(v17)
  let v27: Dict = get_dict Show[Int]
  let v29: Unit = call println(v27, v28)
  v29
