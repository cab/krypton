import core/eq/eq as eq(g, g): Bool
import core/ord/lt as lt(h, h): Bool
import core/semigroup/combine as combine(g, g): g
import core/sub/sub as sub(g, g): g
import core/mul/mul as mul(g, g): g
import core/div/div as div(g, g): g
import core/neg/neg as neg(g): g
import core/show/show as show(g): String
import core/hash/hash as hash(g): Int
import core/resource/close as close(~g): Unit
import core/peek/peek as peek(h): h
import core/list/last as last(List[t3]): Option[t3]
import core/list/sort_by as sort_by(List[y5], (y5) -> n5): List[y5]
import core/list/filter as filter(List[i1], (i1) -> Bool): List[i1]
import core/list/fold as fold(List[v1], x1, (x1, v1) -> x1): x1
import core/list/map as map(List[x], (x) -> z): List[z]
import core/vec/to_list as to_list(Vec[j7]): List[j7]
import core/io/println as println(m): Unit
import core/option/Some as Some(e): Option[e]
import core/option/None as None(): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
import core/list/Nil as Nil(): List[h]
import core/ordering/LT as LT(): Ordering
import core/ordering/EQ as EQ(): Ordering
import core/ordering/GT as GT(): Ordering
import core/map/empty as empty(): Map[t8, u8]
import core/map/put as put(Map[y8, z8], y8, z8): Map[y8, z8]
import core/map/from_list as from_list(List[(e13, f13)]): Map[e13, f13]
import core/map/size as size(Map[l13, m13]): Int
import core/map/merge as merge(Map[r13, s13], Map[r13, s13]): Map[r13, s13]
declare empty: () -> Map[t8, u8]
declare from_list: (List[(e13, f13)]) -> Map[e13, f13]
declare merge: (Map[r13, s13], Map[r13, s13]) -> Map[r13, s13]
declare println: (m) -> Unit
declare put: (Map[y8, z8], y8, z8) -> Map[y8, z8]
declare size: (Map[l13, m13]) -> Int

fn main() -> Unit =
  let v1: Map[String, Int] = call empty()
  let v2: Dict[Eq, String] = get_dict Eq[String]
  let v3: Dict[Hash, String] = get_dict Hash[String]
  let v4: Map[String, Int] = call put(v2, v3, v1, "a", 1)
  let v5: Dict[Eq, String] = get_dict Eq[String]
  let v6: Dict[Hash, String] = get_dict Hash[String]
  let v0: Map[String, Int] = call put(v5, v6, v4, "b", 2)
  let v8: Map[String, Int] = call empty()
  let v9: Dict[Eq, String] = get_dict Eq[String]
  let v10: Dict[Hash, String] = get_dict Hash[String]
  let v7: Map[String, Int] = call put(v9, v10, v8, "c", 3)
  let v12: Dict[Eq, String] = get_dict Eq[String]
  let v13: Dict[Hash, String] = get_dict Hash[String]
  let v11: Map[String, Int] = call merge(v12, v13, v0, v7)
  let v14: Int = call size(v11)
  let v15: Dict[Show, Int] = get_dict Show[Int]
  let v16: Unit = call println(v15, v14)
  let v18: (~String, ~Int) = tuple("x", 10)
  let v19: (~String, ~Int) = tuple("y", 20)
  let v20: (~String, ~Int) = tuple("z", 30)
  let v21: ~List[(~String, ~Int)] = construct List::Nil#1()
  let v22: ~List[(~String, ~Int)] = construct List::Cons#0(v20, v21)
  let v23: ~List[(~String, ~Int)] = construct List::Cons#0(v19, v22)
  let v24: ~List[(~String, ~Int)] = construct List::Cons#0(v18, v23)
  let v25: Dict[Eq, String] = get_dict Eq[String]
  let v26: Dict[Hash, String] = get_dict Hash[String]
  let v17: Map[String, Int] = call from_list(v25, v26, v24)
  let v28: Int = call size(v17)
  let v27: Dict[Show, Int] = get_dict Show[Int]
  let v29: Unit = call println(v27, v28)
  v29
