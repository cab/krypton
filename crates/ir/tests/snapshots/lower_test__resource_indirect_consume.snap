module resource_indirect_consume

type Handle = MkHandle#0(String)
; extern close
; extern println

fn use_handle(v0: ~Handle) -> Unit =
  let v1: Unit = call close(v0)
  v1

fn main() -> Unit =
  let v2: ~Handle = construct Handle::MkHandle#0("test")
  let v3: Unit = call println("opened")
  let v4: Unit = call use_handle(v2)
  v4
