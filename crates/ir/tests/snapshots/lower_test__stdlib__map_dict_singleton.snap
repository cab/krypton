import core/eq/eq as eq(g, g): Bool
import core/ord/lt as lt(h, h): Bool
import core/semigroup/combine as combine(g, g): g
import core/sub/sub as sub(g, g): g
import core/mul/mul as mul(g, g): g
import core/div/div as div(g, g): g
import core/neg/neg as neg(g): g
import core/show/show as show(g): String
import core/hash/hash as hash(g): Int
import core/resource/close as close(~g): Unit
import core/peek/peek as peek(h): h
import core/list/last as last(List[r3]): Option[r3]
import core/list/sort_by as sort_by(List[w5], (w5) -> l5): List[w5]
import core/list/filter as filter(List[h1], (h1) -> Bool): List[h1]
import core/list/fold as fold(List[t1], u1, (u1, t1) -> u1): u1
import core/list/map as map(List[w], (w) -> y): List[y]
import core/vec/to_list as to_list(Vec[h7]): List[h7]
import core/io/println as println(m): Unit
import core/option/Some as Some(e): Option[e]
import core/option/None as None(): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
import core/list/Nil as Nil(): List[h]
import core/ordering/LT as LT(): Ordering
import core/ordering/EQ as EQ(): Ordering
import core/ordering/GT as GT(): Ordering
import core/map/empty as empty(): Map[r8, s8]
import core/map/put as put(Map[w8, x8], w8, x8): Map[w8, x8]
import core/map/get as get(Map[p9, c10], p9): Option[c10]
import core/map/contains as contains(Map[n10, o10], n10): Bool
import core/map/from_list as from_list(List[(c13, d13)]): Map[c13, d13]
import core/map/size as size(Map[j13, k13]): Int
declare contains: (Map[n10, o10], n10) -> Bool
declare empty: () -> Map[r8, s8]
declare from_list: (List[(c13, d13)]) -> Map[c13, d13]
declare get: (Map[p9, c10], p9) -> Option[c10]
declare println: (m) -> Unit
declare put: (Map[w8, x8], w8, x8) -> Map[w8, x8]
declare size: (Map[j13, k13]) -> Int

fn main() -> Unit =
  let v1: Map[String, Int] = call empty()
  let v2: Dict = get_dict Eq[String]
  let v3: Dict = get_dict Hash[String]
  let v4: Map[String, Int] = call put(v2, v3, v1, "a", 42)
  let v5: Dict = get_dict Eq[String]
  let v6: Dict = get_dict Hash[String]
  let v0: Map[String, Int] = call put(v5, v6, v4, "b", 99)
  let_join v32(v15: Unit) =
    let v16: Dict = get_dict Eq[String]
    let v17: Dict = get_dict Hash[String]
    let v18: Bool = call contains(v16, v17, v0, "b")
    let v19: Dict = get_dict Show[Bool]
    let v20: Unit = call println(v19, v18)
    let v22: (~String, ~Int) = tuple("hello", 1)
    let v23: (~String, ~Int) = tuple("world", 2)
    let v24: ~List[(~String, ~Int)] = construct List::Nil#1()
    let v25: ~List[(~String, ~Int)] = construct List::Cons#0(v23, v24)
    let v26: ~List[(~String, ~Int)] = construct List::Cons#0(v22, v25)
    let v27: Dict = get_dict Eq[c13]
    let v28: Dict = get_dict Hash[c13]
    let v21: Map[String, Int] = call from_list(v27, v28, v26)
    let v30: Int = call size(v21)
    let v29: Dict = get_dict Show[Int]
    let v31: Unit = call println(v29, v30)
    v31
  in
  let v7: Dict = get_dict Eq[String]
  let v8: Dict = get_dict Hash[String]
  let v9: Option[Int] = call get(v7, v8, v0, "a")
  switch v9 {
    0 (v10: b) ->
      let v11: Dict = get_dict Show[Int]
      let v12: Unit = call println(v11, v10)
      jump v32(v12)
    1 ->
      let v13: Dict = get_dict Show[Int]
      let v14: Unit = call println(v13, 0)
      jump v32(v14)
  }
