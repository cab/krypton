declare Vec2
declare combine: (g, g) -> g
declare println: (m) -> Unit

fn main() -> Unit =
  let v0: ~Vec2 = call Vec2(1, 1)
  let v1: ~Vec2 = call Vec2(3, 2)
  let_join v11(v9: Int) =
    let v10: Unit = call println(v9)
    v10
  in
  let_join v8(v6: Vec2) =
    let v7: Int = project v6.0
    jump v11(v7)
  in
  let v4: Dict[Semigroup, Vec2] = get_dict Semigroup[Vec2]
  let v5: Vec2 = call combine(v4, v0, v1)
  jump v8(v5)

fn Semigroup$$Vec2$$combine(v12: Vec2, v13: Vec2) -> ~Vec2 =
  let v14: Int = project v12.0
  let v15: Int = project v13.0
  let v16: Int = add_int(v14, v15)
  let v17: Int = project v12.1
  let v18: Int = project v13.1
  let v19: Int = add_int(v17, v18)
  let v20: ~Vec2 = call Vec2(v16, v19)
  v20
