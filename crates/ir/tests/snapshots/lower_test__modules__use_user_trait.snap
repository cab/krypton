declare println: (o) -> Unit

fn main() -> Unit =
  let v1: ~Greeting = construct Greeting::MkGreeting#0("hi")
  let v2: Dict[user_trait_lib.Printable, Greeting] = get_dict user_trait_lib.Printable[Greeting]
  let v3: String = trait_call user_trait_lib.Printable.display(v2, v1)
  let v0: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v4: Unit = call println(v0, v3)
  v4

fn Printable$$Greeting$$display(v5: Greeting) -> ~String =
  "hello"
