module functions__comparison_chain

; extern println

fn main() -> Unit =
  let v0: Bool = lt_int(10, 20)
  let v1: Unit = call println(v0)
  let v2: Bool = gt_int(10, 20)
  let v3: Unit = call println(v2)
  let v4: Bool = le_int(10, 20)
  let v5: Unit = call println(v4)
  let v6: Bool = ge_int(10, 20)
  let v7: Unit = call println(v6)
  let v8: Bool = eq_int(10, 10)
  let v9: Unit = call println(v8)
  let v10: Bool = neq_int(10, 10)
  let v11: Unit = call println(v10)
  v11
