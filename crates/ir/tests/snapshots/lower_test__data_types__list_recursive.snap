module data_types__list_recursive

type List[a] = Cons#0(a, List[a]) | Nil#1

fn length(v0: List[x7]) -> Int =
  switch v0 {
    1 ->
      0
    0 (v1: a, v2: List[a]) ->
      let v3: Int = call length(v2)
