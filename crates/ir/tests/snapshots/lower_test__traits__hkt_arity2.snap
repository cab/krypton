fn Bifunctor$$Pair$$bimap(v0: Pair[r9, s9], v1: (r9) -> v9, v2: (s9) -> w9) -> ~Pair[v9, w9] =
  switch v0 {
    0 (v3: r9, v4: s9) ->
      let v5: v9 = call_closure v1(v3)
      let v6: w9 = call_closure v2(v4)
      let v7: ~Pair[v9, w9] = construct Pair::Pair#0(v5, v6)
      v7
  }
