fn Bifunctor$$Pair$$bimap(v0: Pair[x9, y9], v1: (x9) -> b10, v2: (y9) -> c10) -> ~Pair[b10, c10] =
  switch v0 {
    0 (v3: x9, v4: y9) ->
      let v5: b10 = call_closure v1(v3)
