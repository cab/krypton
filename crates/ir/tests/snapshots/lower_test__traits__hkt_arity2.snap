fn Bifunctor$$Pair$$bimap(v0: Pair[b9, c9], v1: (b9) -> f9, v2: (c9) -> g9) -> ~Pair[f9, g9] =
  switch v0 {
    0 (v3: b9, v4: c9) ->
      let v5: f9 = call_closure v1(v3)
      let v6: g9 = call_closure v2(v4)
      let v7: ~Pair[f9, g9] = construct Pair::Pair#0(v5, v6)
      v7
  }
