fn main() -> Unit =
  let v0: ~List[Int] = construct List::Nil#1()
  let v1: ~List[Int] = construct List::Cons#0(3, v0)
  let v2: ~List[Int] = construct List::Cons#0(2, v1)
  let v3: ~List[Int] = construct List::Cons#0(1, v2)
  let v4: List[Int] = call reverse(v3)
  switch v4 {
    0 (v5: Int, v6: List[e]) ->
      let v7: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v8: Unit = call println(v7, v5)
      v8
    1 ->
      let v9: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v10: Unit = call println(v9, 0)
      v10
  }
