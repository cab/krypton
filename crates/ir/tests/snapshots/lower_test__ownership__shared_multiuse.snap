module ownership__shared_multiuse

; extern println

fn dup(v0: r7) -> (r7, r7) =
  let v1: (r7, r7) = tuple(v0, v0)
  v1

fn test(v2: ~String) -> Unit =
  let v3: (String, String) = call dup(v2)
  let v4: Dict = get_dict Show[String]
  let v5: Unit = call println(v4, v2)
  v5
