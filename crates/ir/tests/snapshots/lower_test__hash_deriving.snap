module hash_deriving

struct Point { x: Int, y: Int }
; extern hash
; extern println

fn main() -> Unit =
  let v0: ~Point = construct Point(1, 2)
  let v1: ~Point = construct Point(1, 2)
  let v2: ~Point = construct Point(3, 4)
  let v3: Int = call hash(v0)
  let v4: Int = call hash(v1)
  let v5: Bool = eq_int(v3, v4)
  let v6: Unit = call println(v5)
  let v7: Int = call hash(v0)
  let v8: Int = call hash(v2)
  let v9: Bool = neq_int(v7, v8)
  let v10: Unit = call println(v9)
  v10
