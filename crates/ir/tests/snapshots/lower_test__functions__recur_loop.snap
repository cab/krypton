    let v5: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
    let v6: Bool = trait_call core/eq.Eq.eq(v5, v3, 0)
    jump v10(v6)
  in
  jump v2(v0, v1)

fn main() -> Unit =
