fn same(v0: Dict[core/eq.Eq, v7], v1: v7, v2: v7) -> Bool =
  let v3: Bool = trait_call core/eq.Eq.eq(v0, v1, v2)
  v3

fn main() -> Unit =
  let_join v15(v13: Bool) =
    let v4: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
    let v14: Unit = call println(v4, v13)
    v14
  in
  let v5: ~A = construct A(1)
  let v6: ~A = construct A(1)
  let v7: Dict[core/eq.Eq, A] = get_dict core/eq.Eq[A]
  let v8: Bool = call same(v7, v5, v6)
  if v8 {
    let v10: ~B = construct B(2)
    let v11: ~B = construct B(2)
    let v9: Dict[core/eq.Eq, B] = get_dict core/eq.Eq[B]
    let v12: Bool = call same(v9, v10, v11)
    jump v15(v12)
  } else {
    jump v15(false)
  }

fn Eq$$A$$eq(v16: A, v17: A) -> Bool =
