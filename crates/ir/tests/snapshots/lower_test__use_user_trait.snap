module use_user_trait

type Greeting = MkGreeting#0(String)
; extern display
; extern println

fn main() -> Unit =
  let v0: ~Greeting = construct Greeting::MkGreeting#0("hi")
  let v1: String = call display(v0)
  let v2: Unit = call println(v1)
  v2
