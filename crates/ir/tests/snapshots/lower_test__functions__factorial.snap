expression: ir_module.to_string()
---
module functions__factorial

declare println: (m) -> Unit

fn factorial(v0: Int) -> Int =
  let v1: Bool = eq_int(v0, 0)
  switch v1 {
    1 ->
      1
    _ ->
      let v2: Int = sub_int(v0, 1)
      let v3: Int = call factorial(v2)
      let v4: Int = mul_int(v0, v3)
      v4
  }

fn main() -> Unit =
  let v5: Int = call factorial(10)
  let v6: Unit = call println(v5)
  v6
