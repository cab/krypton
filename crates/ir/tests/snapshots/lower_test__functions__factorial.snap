declare println: (o) -> Unit

fn factorial(v0: Int) -> Int =
  let_join v7(v3: Bool) =
    if v3 {
      1
    } else {
      let v4: Int = sub_int(v0, 1)
      let v5: Int = call factorial(v4)
      let v6: Int = mul_int(v0, v5)
      v6
    }
  in
  let v1: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
  let v2: Bool = trait_call core/eq.Eq.eq(v1, v0, 0)
  jump v7(v2)

fn main() -> Unit =
  let v9: Int = call factorial(10)
  let v8: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v10: Unit = call println(v8, v9)
  v10
