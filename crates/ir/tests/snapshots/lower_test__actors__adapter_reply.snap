import core/actor/adapter as adapter(Ref[p11], (q11) -> p11): Ref[q11]
declare Reply
declare actor_ref: (Mailbox[a11]) -> Ref[a11]
declare adapter: (Ref[p11], (q11) -> p11) -> Ref[q11]
declare mailbox: () -> Mailbox[m11]
declare println: (Object) -> Unit
declare receive: (Mailbox[r10]) -> r10
declare send: (Ref[g10], g10) -> Unit
declare spawn: ((Mailbox[c10]) -> Unit) -> Ref[c10]

fn value_actor(v0: Mailbox[Msg]) -> Unit =
  let v1: Msg = call receive(v0)
  switch v1 {
    0 (v2: Ref[Int]) ->
      let v3: Unit = call send(v2, 42)
      v3
  }

fn main() -> Unit =
  let v5: (Mailbox[Msg]) -> Unit = make_closure(value_actor, [])
  let v4: Ref[Msg] = call spawn(v5)
  let v6: Mailbox[MainMsg] = call mailbox()
  let v8: Ref[MainMsg] = call actor_ref(v6)
  let v9: (Int) -> MainMsg = make_closure(Reply, [])
  let v7: Ref[Int] = call adapter(v8, v9)
  let v10: ~Msg = construct Msg::Get#0(v7)
  let v11: Unit = call send(v4, v10)
  let v12: MainMsg = call receive(v6)
  switch v12 {
    0 (v13: Int) ->
      let v14: Unit = call println(v13)
      v14
  }
