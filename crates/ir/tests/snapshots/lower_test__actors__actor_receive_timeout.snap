import core/actor/receive_timeout as receive_timeout(Mailbox[i9], Int): Option[i9]
declare receive_timeout: (Mailbox[i9], Int) -> Option[i9]

fn actor(v0: Mailbox[Msg]) -> Unit =
  let_join [recur] v1(v2: Mailbox[Msg]) =
    let v3: Option[Msg] = call receive_timeout(v2, 5000)
    switch v3 {
      0 (v4: b) ->
        switch v4 {
          0 ->
            jump v1(v2)
          1 ->
            jump v1(v2)
        }
      1 ->
        ()
    }
  in
  jump v1(v0)
