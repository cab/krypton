fn test(v0: Option[Int], v1: Option[Int]) -> Int =
  let v2: (Option[Int], Option[Int]) = tuple(v0, v1)
  let v3: Option[Int] = tuple_project v2.0
  let v4: Option[Int] = tuple_project v2.1
  switch v3 {
    0 (v5: Int) ->
      switch v4 {
        0 (v6: Int) ->
          let v7: Int = add_int(v5, v6)
          v7
        1 ->
          v5
      }
    1 ->
      switch v4 {
        0 (v8: Int) ->
          v8
        1 ->
          0
      }
  }
