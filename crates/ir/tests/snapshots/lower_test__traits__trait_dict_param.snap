module traits__trait_dict_param

struct Point { x: Int, y: Int }
declare Point: (Int, Int) -> Point
declare eq: (Dict, g, g) -> Bool
declare println: (m) -> Unit

fn are_equal(v0: Dict, v1: v7, v2: v7) -> Bool =
  let v3: Bool = call eq(v0, v1, v2)
  v3

fn main() -> Unit =
  let v4: ~Point = call Point(1, 2)
  let v5: ~Point = call Point(1, 2)
  let v6: Dict = get_dict Eq[Point]
  let v7: Bool = call are_equal(v6, v4, v5)
  let v8: Unit = call println(v7)
  v8
