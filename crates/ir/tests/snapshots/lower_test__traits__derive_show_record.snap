module traits__derive_show_record

struct Point { x: Int, y: Int }
declare Point: (Int, Int) -> Point
declare println: (m) -> Unit
declare show: (Dict, g) -> String

fn main() -> Unit =
  let v0: ~Point = call Point(1, 2)
  let v1: Dict = get_dict Show[Point]
  let v2: String = call show(v1, v0)
  let v3: Unit = call println(v2)
  v3
