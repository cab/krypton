module traits__constrained_instance_option_ok

type Option[a] = Some#0(a) | None#1
; extern println
; extern show

fn main() -> Unit =
  let v0: ~Option[Int] = construct Option::Some#0(42)
  let v1: Dict = get_dict Show[Int]
  let v2: Dict = make_dict Show[Option[Int]](v1)
  let v3: String = call show(v2, v0)
  let v4: Bool = eq_string(v3, "ok")
  let v5: Unit = call println(v4)
  v5
