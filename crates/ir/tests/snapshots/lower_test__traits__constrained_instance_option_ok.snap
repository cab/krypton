module traits__constrained_instance_option_ok

type Option[a] = Some#0(a) | None#1
declare eq: (Dict, g, g) -> Bool
declare println: (m) -> Unit
declare show: (Dict, g) -> String

fn main() -> Unit =
  let_join v8(v6: Bool) =
    let v7: Unit = call println(v6)
    v7
  in
  let v0: Dict = get_dict Eq[String]
  let v1: ~Option[Int] = construct Option::Some#0(42)
  let v2: Dict = get_dict Show[Int]
  let v3: Dict = make_dict Show[Option[Int]](v2)
  let v4: String = call show(v3, v1)
  let v5: Bool = call eq(v0, v4, "ok")
  jump v8(v5)
