module map_collections

; extern empty
; extern from_list
; extern merge
; extern println
; extern put
; extern size

fn main() -> Unit =
  let v1: Map[String, Int] = call empty()
  let v2: Map[String, Int] = call put(v1, "a", 1)
  let v0: Map[String, Int] = call put(v2, "b", 2)
  let v4: Map[String, Int] = call empty()
  let v3: Map[String, Int] = call put(v4, "c", 3)
  let v5: Map[String, Int] = call merge(v0, v3)
  let v6: Int = call size(v5)
  let v7: Unit = call println(v6)
  let v9: (~String, ~Int) = tuple("x", 10)
  let v10: (~String, ~Int) = tuple("y", 20)
  let v11: (~String, ~Int) = tuple("z", 30)
  let v12: ~List[(~String, ~Int)] = construct List::Nil#1()
  let v13: ~List[(~String, ~Int)] = construct List::Cons#0(v11, v12)
  let v14: ~List[(~String, ~Int)] = construct List::Cons#0(v10, v13)
  let v15: ~List[(~String, ~Int)] = construct List::Cons#0(v9, v14)
  let v8: Map[String, Int] = call from_list(v15)
  let v16: Int = call size(v8)
  let v17: Unit = call println(v16)
  v17
