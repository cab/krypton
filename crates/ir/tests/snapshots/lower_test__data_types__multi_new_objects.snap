module data_types__multi_new_objects

struct Point { x: Int, y: Int }
import core/peek/peek as peek(h): h
import core/list/last as last(List[u3]): Option[u3]
import core/list/sort_by as sort_by(List[z5], (z5) -> o5): List[z5]
import core/list/filter as filter(List[j1], (j1) -> Bool): List[j1]
import core/list/fold as fold(List[w1], y1, (y1, w1) -> y1): y1
import core/list/map as map(List[y], (y) -> a1): List[a1]
import core/vec/to_list as to_list(Vec[y8]): List[y8]
import core/io/println as println(s): Unit
import core/option/Some as Some(e): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
declare println: (s) -> Unit

fn main() -> Unit =
  let v0: ~Point = construct Point(10, 20)
  let v1: ~Point = construct Point(30, 40)
  let v2: Int = project v0.0
  let v3: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v4: Unit = call println(v3, v2)
  let v5: Int = project v0.1
  let v6: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v7: Unit = call println(v6, v5)
  let v8: Int = project v1.0
  let v9: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v10: Unit = call println(v9, v8)
  let v12: Int = project v1.1
  let v11: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v13: Unit = call println(v11, v12)
  v13
