module ownership__own_fn_coerce_to_higher_order

fn apply(v0: ~(t7) -> x7, v1: t7) -> x7 =
  let v2: x7 = call_closure v0(v1)
  v2

fn double(v3: Int) -> Int =
  let v4: Int = mul_int(v3, 2)
  v4

fn test() -> Int =
  let_join v8(v6: (Int) -> Int) =
    let v7: Int = call apply(v6, 21)
    v7
  in
  let v5: (Int) -> Int = make_closure(double, [])
  jump v8(v5)
