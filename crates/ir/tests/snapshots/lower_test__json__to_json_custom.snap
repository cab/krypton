import core/list/sort_by as sort_by(List[w5], (w5) -> l5): List[w5]
import core/list/filter as filter(List[h1], (h1) -> Bool): List[h1]
import core/list/fold as fold(List[t1], u1, (u1, t1) -> u1): u1
import core/list/map as map(List[w], (w) -> y): List[y]
import core/vec/to_list as to_list(Vec[h7]): List[h7]
import core/io/println as println(m): Unit
import core/option/Some as Some(e): Option[e]
import core/option/None as None(): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
import core/list/Nil as Nil(): List[h]
import core/ordering/LT as LT(): Ordering
import core/ordering/EQ as EQ(): Ordering
import core/ordering/GT as GT(): Ordering
import core/list/Cons as Cons(h, List[h]): List[h]
import core/list/Nil as Nil(): List[h]
import core/json/JNum as JNum(Float): Json
import core/json/json_to_string as json_to_string(Json): String
import core/json/json_object as json_object(List[(String, Json)]): Json
import core/json/to_json as to_json(m14): Json
import core/map/from_list as from_list(List[(c13, d13)]): Map[c13, d13]
declare json_object: (List[(String, Json)]) -> Json
declare json_to_string: (Json) -> String
declare println: (m) -> Unit
declare to_json: (m14) -> Json

fn main() -> Unit =
  let v0: ~Point = construct Point(1, 2)
  let v2: Dict = get_dict ToJson[Point]
  let v3: Json = call to_json(v2, v0)
  let v4: String = call json_to_string(v3)
  let v1: Dict = get_dict Show[String]
  let v5: Unit = call println(v1, v4)
  v5

fn ToJson$$Point$$to_json(v6: Point) -> Json =
  let v7: Int = project v6.0
  let v8: Dict = get_dict ToJson[Int]
  let v9: Json = call to_json(v8, v7)
  let v10: (~String, Json) = tuple("x", v9)
  let v11: Int = project v6.1
  let v12: Dict = get_dict ToJson[Int]
  let v13: Json = call to_json(v12, v11)
  let v14: (~String, Json) = tuple("y", v13)
  let v15: ~List[(~String, Json)] = construct List::Nil#1()
  let v16: ~List[(~String, Json)] = construct List::Cons#0(v14, v15)
  let v17: ~List[(~String, Json)] = construct List::Cons#0(v10, v16)
  let v18: Json = call json_object(v17)
  v18
