fn main() -> Unit =
  let v0: ~Point = construct Point(1, 2)
  let v2: Dict[core/json.ToJson, Point] = get_dict core/json.ToJson[Point]
  let v3: Json = trait_call core/json.ToJson.to_json(v2, v0)
  let v4: String = call json_to_string(v3)
  let v1: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v5: Unit = call println(v1, v4)
  v5

fn ToJson$$Point$$to_json(v6: Point) -> Json =
  let v7: Int = project v6.0
  let v8: Dict[core/json.ToJson, Int] = get_dict core/json.ToJson[Int]
  let v9: Json = trait_call core/json.ToJson.to_json(v8, v7)
  let v10: (~String, Json) = tuple("x", v9)
  let v11: Int = project v6.1
  let v12: Dict[core/json.ToJson, Int] = get_dict core/json.ToJson[Int]
  let v13: Json = trait_call core/json.ToJson.to_json(v12, v11)
  let v14: (~String, Json) = tuple("y", v13)
  let v15: ~List[(~String, Json)] = construct List::Nil#1()
  let v16: ~List[(~String, Json)] = construct List::Cons#0(v14, v15)
  let v17: ~List[(~String, Json)] = construct List::Cons#0(v10, v16)
  let v18: Json = call json_object(v17)
  v18
