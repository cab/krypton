module json__to_json_custom

struct Point { x: Int, y: Int }
declare json_to_string: (Json) -> String
declare println: (Dict, m) -> Unit
declare to_json: (Dict, i14) -> Json

fn main() -> Unit =
  let v0: ~Point = construct Point(1, 2)
  let v1: Dict = get_dict ToJson[Point]
  let v2: Json = call to_json(v1, v0)
  let v3: String = call json_to_string(v2)
  let v4: Dict = get_dict Show[String]
  let v5: Unit = call println(v4, v3)
  v5
