module trait_dict_param

struct Point { x: Int, y: Int }
; extern Point
; extern eq
; extern println

fn are_equal(v0: t7, v1: t7) -> Bool =
  let v2: Bool = call eq(v0, v1)
  v2

fn main() -> Unit =
  let v3: ~Point = call Point(1, 2)
  let v4: ~Point = call Point(1, 2)
  let v5: Bool = call are_equal(v3, v4)
  let v6: Unit = call println(v5)
  v6
