module string_parse

; extern parse_float
; extern parse_int
; extern println

fn main() -> Unit =
  let v0: Option[Int] = call parse_int("42")
  let v1: Unit = call println(v0)
  let v2: Option[Int] = call parse_int("abc")
  let v3: Unit = call println(v2)
  let v4: Option[Float] = call parse_float("3.14")
  let v5: Unit = call println(v4)
  let v6: Option[Float] = call parse_float("xyz")
  let v7: Unit = call println(v6)
  v7
