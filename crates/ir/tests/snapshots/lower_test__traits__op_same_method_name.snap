declare combine: (g, g) -> g
declare join
declare println: (m) -> Unit
declare show: (g) -> String

fn apply_combine(v0: Dict[Semigroup, a8], v1: a8, v2: a8) -> a8 =
  let v3: a8 = call combine(v0, v1, v2)
  v3

fn apply_join(v4: Dict[Joinable, g8], v5: g8, v6: g8) -> g8 =
  let v7: g8 = call join(v4, v5, v6)
  v7

fn main() -> Unit =
  let v8: Dict[Semigroup, Int] = get_dict Semigroup[Int]
  let v9: Int = call apply_combine(v8, 1, 2)
  let v10: Dict[Show, Int] = get_dict Show[Int]
  let v11: String = call show(v10, v9)
  let v12: Dict[Show, String] = get_dict Show[String]
  let v13: Unit = call println(v12, v11)
  let v15: Dict[Joinable, String] = get_dict Joinable[String]
  let v16: String = call apply_join(v15, "hello", "world")
  let v14: Dict[Show, String] = get_dict Show[String]
  let v17: Unit = call println(v14, v16)
  v17

fn Joinable$$String$$join(v18: String, v19: String) -> String =
  let v20: String = concat_string(v18, " ")
  let v21: String = concat_string(v20, v19)
