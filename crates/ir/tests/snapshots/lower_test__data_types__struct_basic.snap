module data_types__struct_basic

struct Point { x: Int, y: Int }
; extern Point
; extern println

fn main() -> Unit =
  let v0: ~Point = call Point(10, 20)
  let v1: Int = project v0.0
  let v2: Int = project v0.1
  let v3: Int = add_int(v1, v2)
  let v4: Unit = call println(v3)
  v4
