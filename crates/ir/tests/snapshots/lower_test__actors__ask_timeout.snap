import core/actor/ask as ask(Ref[l10], (Ref[m10]) -> l10, Int): Result[Timeout, m10]
import core/result/Ok as Ok(h): Result[g, h]
import core/result/Err as Err(g): Result[g, h]
declare Get
declare ask: (Ref[l10], (Ref[m10]) -> l10, Int) -> Result[Timeout, m10]
declare println: (m) -> Unit
declare spawn: ((Mailbox[n8]) -> Unit) -> Ref[n8]

fn dead_actor(v0: Mailbox[Msg]) -> Unit =
  ()

fn main() -> Unit =
  let v2: (Mailbox[Msg]) -> Unit = make_closure(dead_actor, [])
  let v1: Ref[Msg] = call spawn(v2)
  let v3: (Ref[Int]) -> Msg = make_closure(Get, [])
  let v4: Result[Timeout, Int] = call ask(v1, v3, 100)
  switch v4 {
    0 (v5: Int) ->
      let v6: Unit = call println(v5)
      v6
    1 (v7: c) ->
      switch v7 {
        0 ->
          let v8: Unit = call println("timeout")
          v8
      }
  }
