declare println: (m) -> Unit

fn side_effect() -> Unit =
  let v0: ~Int = 1
  ()

fn explicit_unit() -> Unit =
  ()

fn multi_let() -> Unit =
  let v1: ~Int = 1
  let v2: ~Int = 2
  ()

fn call_void() -> Unit =
  let v3: Unit = call side_effect()
  v3

fn expr_discarded() -> Unit =
  let v4: ~String = "hi"
  ()

fn main() -> Unit =
  let v5: Unit = call side_effect()
  let v6: Unit = call explicit_unit()
  let v7: Unit = call multi_let()
  let v8: Unit = call call_void()
  let v9: Unit = call expr_discarded()
  let v10: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v11: Unit = call println(v10, "done")
  v11
