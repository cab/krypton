module ownership__fn_to_own_fn_coerce

declare println: (Dict, m) -> Unit

fn call_once(v0: ~() -> String) -> String =
  let v1: String = call_closure v0()
  v1

fn make_fn() -> String =
  "hello"

fn main() -> Unit =
  let v3: () -> String = make_closure(make_fn, [])
  let v4: String = call call_once(v3)
