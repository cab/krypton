module traits__op_div_syntax

struct Vec2 { x: Int, y: Int }
declare Vec2: (Int, Int) -> Vec2
declare div: (Dict, g, g) -> g
declare println: (m) -> Unit

fn main() -> Unit =
  let v0: ~Vec2 = call Vec2(6, 8)
  let v1: ~Vec2 = call Vec2(2, 4)
  let_join v11(v9: Int) =
    let v10: Unit = call println(v9)
    v10
  in
  let_join v8(v6: Vec2) =
    let v7: Int = project v6.0
    jump v11(v7)
  in
  let v4: Dict = get_dict Div[Vec2]
  let v5: Vec2 = call div(v4, v0, v1)
  jump v8(v5)
