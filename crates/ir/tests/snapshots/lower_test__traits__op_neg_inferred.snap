declare println: (o) -> Unit

fn negate(v0: Dict[core/neg.Neg, o8], v1: o8) -> o8 =
  let v2: o8 = trait_call core/neg.Neg.neg(v0, v1)
  v2

fn main() -> Unit =
  let v4: Dict[core/neg.Neg, Int] = get_dict core/neg.Neg[Int]
  let v5: Int = call negate(v4, 5)
  let v6: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v7: String = trait_call core/show.Show.show(v6, v5)
  let v3: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v8: Unit = call println(v3, v7)
  v8
