module traits__op_ord_user_type

struct Wrapper { val: Int }
instance core/eq.Eq[Wrapper] { eq=Eq$$Wrapper$$eq }
instance core/ord.Ord[Wrapper] { lt=Ord$$Wrapper$$lt }
