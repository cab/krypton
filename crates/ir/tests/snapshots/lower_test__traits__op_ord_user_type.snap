declare println: (s) -> Unit

fn main() -> Unit =
  let v1: ~Wrapper = construct Wrapper(1)
  let v2: ~Wrapper = construct Wrapper(2)
  let v3: Dict[core/ord.Ord, Wrapper] = get_dict core/ord.Ord[Wrapper]
  let v4: Bool = trait_call core/ord.Ord.lt(v3, v1, v2)
  let v0: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
  let v5: Unit = call println(v0, v4)
  v5

fn Eq$$Wrapper$$eq(v6: Wrapper, v7: Wrapper) -> Bool =
  let v8: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
  let v9: Int = project v6.0
  let v10: Int = project v7.0
  let v11: Bool = trait_call core/eq.Eq.eq(v8, v9, v10)
  v11

fn Ord$$Wrapper$$lt(v12: Wrapper, v13: Wrapper) -> Bool =
  let v14: Dict[core/ord.Ord, Int] = get_dict core/ord.Ord[Int]
  let v15: Int = project v12.0
  let v16: Int = project v13.0
  let v17: Bool = trait_call core/ord.Ord.lt(v14, v15, v16)
