module resources__resource_indirect_consume

type Handle = MkHandle#0(String)
declare close: (Dict, ~g) -> Unit
declare println: (m) -> Unit

fn use_handle(v0: ~Handle) -> Unit =
  let v1: Dict = get_dict Resource[Handle]
  let v2: Unit = call close(v1, v0)
  v2

fn main() -> Unit =
  let v3: ~Handle = construct Handle::MkHandle#0("test")
  let v4: Unit = call println("opened")
  let v5: Unit = call use_handle(v3)
  v5
