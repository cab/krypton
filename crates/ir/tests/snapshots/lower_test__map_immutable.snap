module map_immutable

; extern contains
; extern empty
; extern println
; extern put

fn main() -> Unit =
  let v0: Map[x10, y10] = call empty()
  let v1: Map[String, Int] = call put(v0, "x", 1)
  let v2: Bool = call contains(v0, "x")
  let v3: Unit = call println(v2)
  let v4: Bool = call contains(v1, "x")
  let v5: Unit = call println(v4)
  v5
