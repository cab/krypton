fn make_pair() -> (Int, ~Handle) =
  let v0: ~Handle = construct Handle::MkHandle#0("test")
  let v1: (~Int, ~Handle) = tuple(1, v0)
  v1

fn main() -> Unit =
  let v2: (Int, ~Handle) = call make_pair()
  let v3: Int = tuple_project v2.0
  let v4: ~Handle = tuple_project v2.1
  let v5: Unit = call println("opened")
  let v6: Dict[core/resource.Resource, Handle] = get_dict core/resource.Resource[Handle]
  let v7: Unit = trait_call core/resource.Resource.close(v6, v4)
  v5

fn Resource$$Handle$$close(v8: ~Handle) -> Unit =
  let v9: Unit = call println("closed")
  v9
