module to_json_custom

struct Point { x: Int, y: Int }
; extern json_to_string
; extern println
; extern to_json

fn main() -> Unit =
  let v0: ~Point = construct Point(1, 2)
  let v1: Json = call to_json(v0)
  let v2: String = call json_to_string(v1)
  let v3: Unit = call println(v2)
  v3
