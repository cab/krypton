module resources__resource_lifo

type HandleA = MkHandleA#0(Int)
type HandleB = MkHandleB#0(Int)
instance core/resource.Resource[HandleA] { close=Resource$$HandleA$$close }
instance core/resource.Resource[HandleB] { close=Resource$$HandleB$$close }
extern java "krypton.runtime.KryptonIO" println(Object): Unit
import core/peek/peek as peek(h): h
import core/list/last as last(List[u3]): Option[u3]
import core/list/sort_by as sort_by(List[z5], (z5) -> o5): List[z5]
import core/list/filter as filter(List[j1], (j1) -> Bool): List[j1]
import core/list/fold as fold(List[w1], y1, (y1, w1) -> y1): y1
import core/list/map as map(List[y], (y) -> a1): List[a1]
import core/vec/to_list as to_list(Vec[c8]): List[c8]
import core/option/Some as Some(e): Option[e]
import core/result/Ok as Ok(g): Result[f, g]
import core/result/Err as Err(f): Result[f, g]
import core/list/Cons as Cons(h, List[h]): List[h]
declare println: (Object) -> Unit

fn main() -> Unit =
  let v0: ~HandleA = construct HandleA::MkHandleA#0(1)
  let v1: Unit = call println("a")
  let v2: ~HandleB = construct HandleB::MkHandleB#0(2)
  let v3: Unit = call println("b")
  let v4: Dict[core/resource.Resource, HandleB] = get_dict core/resource.Resource[HandleB]
  let v7: Unit = trait_call core/resource.Resource.close(v4, v2)
  let v5: Dict[core/resource.Resource, HandleA] = get_dict core/resource.Resource[HandleA]
  let v6: Unit = trait_call core/resource.Resource.close(v5, v0)
  v3

fn Resource$$HandleA$$close(v8: ~HandleA) -> Unit =
  let v9: Unit = call println("close_a")
  v9

fn Resource$$HandleB$$close(v10: ~HandleB) -> Unit =
  let v11: Unit = call println("close_b")
  v11
