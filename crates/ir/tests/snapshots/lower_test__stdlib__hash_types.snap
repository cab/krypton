module stdlib__hash_types

; extern hash
; extern println

fn main() -> Unit =
  let v0: Dict = get_dict Hash[Int]
  let v1: Int = call hash(v0, 42)
  let v2: Dict = get_dict Hash[Int]
  let v3: Int = call hash(v2, 42)
  let v4: Bool = eq_int(v1, v3)
  let v5: Dict = get_dict Show[Bool]
  let v6: Unit = call println(v5, v4)
  let v7: Dict = get_dict Hash[Float]
  let v8: Int = call hash(v7, 3.14)
  let v9: Dict = get_dict Hash[Float]
  let v10: Int = call hash(v9, 3.14)
  let v11: Bool = eq_int(v8, v10)
  let v12: Dict = get_dict Show[Bool]
  let v13: Unit = call println(v12, v11)
  let v14: Dict = get_dict Hash[String]
  let v15: Int = call hash(v14, "hello")
  let v16: Dict = get_dict Hash[String]
  let v17: Int = call hash(v16, "hello")
  let v18: Bool = eq_int(v15, v17)
  let v19: Dict = get_dict Show[Bool]
  let v20: Unit = call println(v19, v18)
  let v21: Dict = get_dict Hash[Bool]
  let v22: Int = call hash(v21, true)
  let v23: Dict = get_dict Hash[Bool]
  let v24: Int = call hash(v23, true)
  let v25: Bool = eq_int(v22, v24)
  let v26: Dict = get_dict Show[Bool]
  let v27: Unit = call println(v26, v25)
  v27
