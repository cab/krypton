module stdlib__hash_types

declare eq: (Dict, g, g) -> Bool
declare hash: (Dict, g) -> Int
declare println: (Dict, m) -> Unit

fn main() -> Unit =
  let v8: Bool = call $thunk_49()
  let v9: Dict = get_dict Show[Bool]
  let v10: Unit = call println(v9, v8)
  let v19: Bool = call $thunk_50()
  let v20: Dict = get_dict Show[Bool]
  let v21: Unit = call println(v20, v19)
  let v30: Bool = call $thunk_51()
  let v31: Dict = get_dict Show[Bool]
  let v32: Unit = call println(v31, v30)
  let_join v42(v40: Bool) =
    let v33: Dict = get_dict Show[Bool]
    let v41: Unit = call println(v33, v40)
    v41
  in
  let v34: Dict = get_dict Eq[Int]
  let v35: Dict = get_dict Hash[Bool]
  let v36: Int = call hash(v35, true)
  let v37: Dict = get_dict Hash[Bool]
  let v38: Int = call hash(v37, true)
  let v39: Bool = call eq(v34, v36, v38)
  jump v42(v39)

