module struct_update_replaces_own

struct Buf { name: String, data: ~String }

fn test(v0: ~Buf, v1: ~String) -> String =
  let_join v6(v2: ~Buf) =
    let v5: String = project v0.0
    v5
  in
  let v3: String = project v0.0
  let v4: ~Buf = construct Buf(v3, v1)
  jump v6(v4)
