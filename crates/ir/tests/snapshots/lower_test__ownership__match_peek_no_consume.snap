module ownership__match_peek_no_consume

type Choice = A#0 | B#1

fn peek(v0: h) -> h =
  let v1: ~Choice = construct Choice::A#0()
  v1

fn consume(v2: ~String) -> String =
  v2

fn test(v3: ~String) -> String =
  let_join v7(v5: ~Int) =
    let v6: String = call consume(v3)
    v6
  in
  let v4: Choice = call peek(v3)
  switch v4 {
    0 ->
      jump v7(0)
    1 ->
      jump v7(0)
  }
