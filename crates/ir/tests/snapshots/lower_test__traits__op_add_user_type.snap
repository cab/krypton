declare Vec2
declare combine: (g, g) -> g
declare println: (m) -> Unit

fn main() -> Unit =
  let v0: ~Vec2 = call Vec2(1, 1)
  let v1: ~Vec2 = call Vec2(3, 2)
  let v2: Dict = get_dict Semigroup[Vec2]
  let v3: Vec2 = call combine(v2, v0, v1)
  let v4: Int = project v3.0
  let v5: Unit = call println(v4)
  v5

fn Semigroup$$Vec2$$combine(v6: Vec2, v7: Vec2) -> ~Vec2 =
  let v8: Int = project v6.0
  let v9: Int = project v7.0
  let v10: Int = add_int(v8, v9)
  let v11: Int = project v6.1
  let v12: Int = project v7.1
  let v13: Int = add_int(v11, v12)
  let v14: ~Vec2 = call Vec2(v10, v13)
  v14
