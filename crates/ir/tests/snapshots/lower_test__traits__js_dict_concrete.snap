  let v5: ~Point = construct Point(1, 2)
  let v6: ~Point = construct Point(1, 2)
  let v7: Bool = call check(v5, v6)
  let v4: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
  let v8: Unit = call println(v4, v7)
