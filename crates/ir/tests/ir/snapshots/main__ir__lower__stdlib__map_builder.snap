declare size: (Map[c14, d14]) -> Int

fn main() -> Unit =
  let v0: ~MapBuilder[q14, r14] = call builder()
  let v2: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v3: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v1: ~MapBuilder[String, Int] = call put(v2, v3, v0, "a", 1)
  let v5: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v6: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v4: ~MapBuilder[String, Int] = call put(v5, v6, v1, "b", 2)
  let v8: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v9: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v7: ~MapBuilder[String, Int] = call put(v8, v9, v4, "answer", 42)
  let v10: Map[String, Int] = call freeze(v7)
  let v11: Int = call size(v10)
  let v12: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v13: Unit = call println(v12, v11)
  let v14: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v15: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v16: Option[Int] = call get(v14, v15, v10, "answer")
  switch v16 {
    0 (v17: Int) ->
      let v18: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v19: Unit = call println(v18, v17)
      v19
    1 ->
      let v20: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v21: Unit = call println(v20, 0)
      v21
  }
