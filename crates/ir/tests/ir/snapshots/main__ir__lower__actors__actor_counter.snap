      1 ->
        let v7: Int = sub_int(v4, 1)
        jump v2(v3, v7)
      2 (v8: Ref[Int]) ->
        let v9: Unit = call send(v8, v4)
        jump v2(v3, v4)
    }
  in
  jump v2(v0, v1)

fn main() -> Unit =
  let v10: (Mailbox[CounterMsg], Int) -> Never = make_closure(counter, [])
  let v11: (Mailbox[CounterMsg], Int) -> Never = v10
