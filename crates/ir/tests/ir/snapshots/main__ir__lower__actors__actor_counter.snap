import core/actor/spawn as spawn((Mailbox[i13]) -> Unit) -> Ref[i13]
import core/actor/send as send(Ref[l13], l13) -> Unit
import core/actor/receive as receive(Mailbox[u13]) -> u13
declare receive: (Mailbox[u13]) -> u13
declare send: (Ref[l13], l13) -> Unit

fn counter(v0: Mailbox[CounterMsg], v1: Int) -> Never =
  let_join [recur] v2(v3: Mailbox[CounterMsg], v4: Int) =
    let v5: CounterMsg = call receive(v3)
    switch v5 {
      0 ->
        let v6: Int = add_int(v4, 1)
        jump v2(v3, v6)
      1 ->
        let v7: Int = sub_int(v4, 1)
        jump v2(v3, v7)
      2 (v8: Ref[Int]) ->
        let v9: Unit = call send(v8, v4)
        jump v2(v3, v4)
    }
  in
  jump v2(v0, v1)

fn main() -> Unit =
  let v10: (Mailbox[CounterMsg], Int) -> Never = make_closure(counter, [])
  let v11: (Mailbox[CounterMsg], Int) -> Never = v10
  ()
