declare println: (g) -> Unit

fn classify(v0: Option[Expr]) -> String =
  switch v0 {
    0 (v1: a) ->
      switch v1 {
        0 (v2: Int) ->
          "lit"
        1 (v3: Expr) ->
          switch v3 {
            0 (v4: Int) ->
              "lit"
            _ ->
              "other"
          }
        _ ->
          "other"
      }
    _ ->
      "other"
  }

fn main() -> Unit =
