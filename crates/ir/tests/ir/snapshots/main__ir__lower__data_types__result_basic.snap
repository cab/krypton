fn extract(v0: Result[r8, Int]) -> Int =
  switch v0 {
    0 (v1: Int) ->
      v1
    1 (v2: r8) ->
      let v3: Int = sub_int(0, 1)
      v3
  }

fn test() -> Int =
  let v4: ~Result[w8, Int] = construct Result::Ok#0(42)
  let v5: Int = call extract(v4)
  v5
