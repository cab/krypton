fn consume_box(v0: ~Box) -> Box =
  let v1: Int = project v0.0
  let v2: Box = construct Box(v1)
  v2

fn test_ctor() -> Box =
  let v3: ~Box = construct Box(1)
  let v4: Box = call consume_box(v3)
  v4
