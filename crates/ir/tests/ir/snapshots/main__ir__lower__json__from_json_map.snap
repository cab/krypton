  let v0: ~Json = construct Json::JObj#5(v7)
  let v9: Dict[core/json.FromJson, Int] = get_dict core/json.FromJson[Int]
  let v10: Dict[core/json.FromJson, Map[String, Int]] = make_dict core/json.FromJson[Map[String, Int]](v9)
  let v8: Result[String, Map[String, Int]] = trait_call core/json.FromJson.from_json(v10, v0)
  switch v8 {
    0 (v11: Map[String, Int]) ->
      let v12: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
      let v13: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
      let v14: Option[Int] = call get(v12, v13, v11, "x")
      switch v14 {
        0 (v15: Int) ->
          let v16: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
          let v17: Unit = call println(v16, v15)
          v17
        1 ->
          let v18: Dict[core/show.Show, String] = get_dict core/show.Show[String]
          let v19: Unit = call println(v18, "missing")
          v19
      }
    1 (v20: String) ->
      let v21: Dict[core/show.Show, String] = get_dict core/show.Show[String]
      let v22: Unit = call println(v21, v20)
      v22
  }
