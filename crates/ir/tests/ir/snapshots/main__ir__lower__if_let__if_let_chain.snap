          }
      }
    _ ->
      switch v0 {
        1 (v5: Result[String, Int]) ->
          switch v5 {
            0 (v6: c) ->
              "second"
            _ ->
              "neither"
          }
        _ ->
          "neither"
      }
  }

fn main() -> Unit =
