fn classify(v0: Input) -> String =
  switch v0 {
    0 (v1: Option[Int]) ->
      switch v1 {
        0 (v2: a) ->
          "first"
        _ ->
          switch v0 {
            1 (v3: Result[String, Int]) ->
              switch v3 {
                0 (v4: c) ->
                  "second"
                _ ->
                  "neither"
              }
            _ ->
