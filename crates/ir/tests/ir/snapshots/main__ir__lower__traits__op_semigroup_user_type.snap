fn main() -> Unit =
  let v1: Vec2 = construct Vec2(1, 1)
  let v2: Vec2 = construct Vec2(3, 2)
  let v3: Dict[core/semigroup.Semigroup, Vec2] = get_dict core/semigroup.Semigroup[Vec2]
  let v4: Vec2 = trait_call core/semigroup.Semigroup.combine(v3, v1, v2)
  let v5: Int = project v4.0
  let v0: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v6: Unit = call println(v0, v5)
  v6

fn Semigroup$$Vec2$$combine(v7: Vec2, v8: Vec2) -> Vec2 =
  let v9: Int = project v7.0
  let v10: Int = project v8.0
  let v11: Int = add_int(v9, v10)
  let v12: Int = project v7.1
  let v13: Int = project v8.1
  let v14: Int = add_int(v12, v13)
  let v15: Vec2 = construct Vec2(v11, v14)
  v15
