module stdlib__vec_get

import core/peek/peek as peek(d) -> d
import core/list/last as last(List[p3]) -> Option[p3]
import core/list/sort_by as sort_by(List[u5], (u5) -> j5) -> List[u5]
import core/list/filter as filter(List[f1], (f1) -> Bool) -> List[f1]
import core/list/fold as fold(List[s1], u1, (u1, s1) -> u1) -> u1
import core/list/map as map(List[u], (u) -> w) -> List[w]
import core/vec/to_list as to_list(Vec[x7]) -> List[x7]
import core/io/println as println(g) -> Unit
import core/option/Some as Some(b) -> Option[b]
import core/result/Ok as Ok(d) -> Result[c, d]
import core/result/Err as Err(c) -> Result[c, d]
import core/list/Cons as Cons(e, List[e]) -> List[e]
import core/vec/nth as nth(Vec[g7], Int) -> Option[g7]
declare nth: (Vec[g7], Int) -> Option[g7]
declare println: (g) -> Unit

fn main() -> Unit =
  let v0: Vec[Int] = make_vec(1, 2, 3)
  let v1: Option[Int] = call nth(v0, 0)
  switch v1 {
    0 (v2: Int) ->
      let v3: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v4: Unit = call println(v3, v2)
      v4
    1 ->
      let v5: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v6: Unit = call println(v5, 0)
      v6
  }
