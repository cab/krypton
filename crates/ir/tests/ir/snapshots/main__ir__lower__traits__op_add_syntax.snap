  let v5: Dict[core/semigroup.Semigroup, Vec2] = get_dict core/semigroup.Semigroup[Vec2]
  let v6: Vec2 = trait_call core/semigroup.Semigroup.combine(v5, v0, v1)
  jump v9(v6)

fn Semigroup$$Vec2$$combine(v13: Vec2, v14: Vec2) -> Vec2 =
  let v15: Int = project v13.0
  let v16: Int = project v14.0
  let v17: Int = add_int(v15, v16)
  let v18: Int = project v13.1
  let v19: Int = project v14.1
  let v20: Int = add_int(v18, v19)
  let v21: Vec2 = construct Vec2(v17, v20)
