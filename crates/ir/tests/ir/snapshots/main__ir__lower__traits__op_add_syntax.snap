fn main() -> Unit =
  let v0: Vec2 = construct Vec2(1, 1)
  let v1: Vec2 = construct Vec2(3, 2)
  let_join v12(v10: Int) =
    let v2: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
    let v11: Unit = call println(v2, v10)
    v11
  in
  let_join v9(v7: Vec2) =
