module actors__actor_receive_timeout

type Msg = Ping#0 | Pong#1
import core/peek/peek as peek(d) -> d
import core/list/last as last(List[f3]) -> Option[f3]
import core/list/sort_by as sort_by(List[k5], (k5) -> z4) -> List[k5]
import core/list/filter as filter(List[g1], (g1) -> Bool) -> List[g1]
import core/list/fold as fold(List[t1], u1, (u1, t1) -> u1) -> u1
import core/list/map as map(List[v], (v) -> x) -> List[x]
import core/vec/to_list as to_list(Vec[q10]) -> List[q10]
import core/io/println as println(g) -> Unit
import core/option/Some as Some(b) -> Option[b]
import core/result/Ok as Ok(d) -> Result[c, d]
import core/result/Err as Err(c) -> Result[c, d]
import core/list/Cons as Cons(e, List[e]) -> List[e]
import core/actor/receive_timeout as receive_timeout(Mailbox[p12], Int) -> Option[p12]
declare receive_timeout: (Mailbox[p12], Int) -> Option[p12]

fn actor(v0: Mailbox[Msg]) -> Unit =
  let_join [recur] v1(v2: Mailbox[Msg]) =
    let v3: Option[Msg] = call receive_timeout(v2, 5000)
    switch v3 {
      0 (v4: c) ->
        switch v4 {
          0 ->
            jump v1(v2)
          1 ->
            jump v1(v2)
        }
      1 ->
        ()
    }
  in
  jump v1(v0)
