import core/result/Err as Err(d) -> Result[d, e]
import core/list/Cons as Cons(f, List[f]) -> List[f]

fn map_option(v0: Option[s8], v1: (s8) -> t8) -> Option[t8] =
  switch v0 {
    0 (v2: s8) ->
      let v3: t8 = call_closure v1(v2)
      let v4: Option[t8] = construct Option::Some#0(v3)
      v4
    1 ->
      let v5: Option[t8] = construct Option::None#1()
      v5
  }
