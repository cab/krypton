fn map_option(v0: Option[k11], v1: (k11) -> l11) -> Option[l11] =
  switch v0 {
    0 (v2: k11) ->
      let v3: l11 = call_closure v1(v2)
      let v4: Option[l11] = construct Option::Some#0(v3)
      v4
    1 ->
      let v5: Option[l11] = construct Option::None#1()
      v5
  }
