import core/option/Some as Some(b) -> Option[b]
import core/result/Ok as Ok(d) -> Result[c, d]
import core/result/Err as Err(c) -> Result[c, d]
import core/list/Cons as Cons(e, List[e]) -> List[e]

fn map_option(v0: Option[q11], v1: (q11) -> r11) -> Option[r11] =
  switch v0 {
    0 (v2: q11) ->
      let v3: r11 = call_closure v1(v2)
      let v4: Option[r11] = construct Option::Some#0(v3)
      v4
    1 ->
      let v5: Option[r11] = construct Option::None#1()
      v5
  }
