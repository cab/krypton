declare println: (g) -> Unit

fn show_opt(v0: Option[Int]) -> String =
  switch v0 {
    0 (v1: Int) ->
      let v2: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v3: String = trait_call core/show.Show.show(v2, v1)
      let v4: String = concat_string("got ", v3)
      v4
    _ ->
      "none"
  }

fn main() -> Unit =
  let v5: Option[Int] = construct Option::Some#0(42)
  let v6: String = call show_opt(v5)
  let v7: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v8: Unit = call println(v7, v6)
  let v10: Option[Int] = construct Option::None#1()
  let v11: String = call show_opt(v10)
  let v9: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v12: Unit = call println(v9, v11)
  v12
