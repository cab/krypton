  let v10: (String, Json) = tuple("x", v9)
  let v11: Int = project v6.1
  let v12: Dict[core/json.ToJson, Int] = get_dict core/json.ToJson[Int]
  let v13: Json = trait_call core/json.ToJson.to_json(v12, v11)
  let v14: (String, Json) = tuple("y", v13)
  let v15: List[(String, Json)] = construct List::Nil#1()
  let v16: List[(String, Json)] = construct List::Cons#0(v14, v15)
