module functions__fibonacci

import core/peek/peek as peek(d) -> d
import core/list/last as last(List[i4]) -> Option[i4]
import core/list/sort_by as sort_by(List[n6], (n6) -> c6) -> List[n6]
import core/list/filter as filter(List[h1], (h1) -> Bool) -> List[h1]
import core/vec/to_list as to_list(Vec[a12]) -> List[a12]
import core/io/println as println(g) -> Unit
import core/option/Some as Some(b) -> Option[b]
import core/result/Ok as Ok(d) -> Result[c, d]
import core/result/Err as Err(c) -> Result[c, d]
import core/list/Cons as Cons(e, List[e]) -> List[e]
declare println: (g) -> Unit

fn fibonacci(v0: Int) -> Int =
  let_join v10(v4: Bool) =
    if v4 {
      v0
    } else {
      let v5: Int = sub_int(v0, 1)
      let v6: Int = call fibonacci(v5)
      let v7: Int = sub_int(v0, 2)
      let v8: Int = call fibonacci(v7)
      let v9: Int = add_int(v6, v8)
      v9
    }
  in
  let v1: Dict[core/ord.Ord, Int] = get_dict core/ord.Ord[Int]
  let v2: Bool = trait_call core/ord.Ord.lt(v1, 1, v0)
  let v3: Bool = not(v2)
  jump v10(v3)

fn main() -> Unit =
  let v12: Int = call fibonacci(10)
  let v11: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v13: Unit = call println(v11, v12)
  v13
