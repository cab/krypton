      let v16: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
      let v17: Int = project v9.1
      let v18: Int = project v10.1
      let v19: Bool = trait_call core/eq.Eq.eq(v16, v17, v18)
