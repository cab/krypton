fn consume(v0: ~Option[Int]) -> Option[Int] =
  switch v0 {
    0 (v1: Int) ->
      let v2: Option[Int] = construct Option::Some#0(v1)
      v2
    1 ->
      let v3: Option[Int] = construct Option::None#1()
      v3
  }

fn make() -> ~Option[Int] =
  let v4: ~Option[Int] = construct Option::Some#0(0)
  v4

fn loop(v5: ~Option[Int], v6: Int) -> Option[Int] =
  let_join [recur] v7(v8: ~Option[Int], v9: Int) =
    let_join v17(v12: Bool) =
      if v12 {
        let v13: Option[Int] = call consume(v8)
        v13
      } else {
        let v14: Option[Int] = call consume(v8)
        let v15: ~Option[Int] = call make()
        let v16: Int = sub_int(v9, 1)
        jump v7(v15, v16)
      }
    in
    let v10: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
    let v11: Bool = trait_call core/eq.Eq.eq(v10, v9, 0)
    jump v17(v11)
  in
