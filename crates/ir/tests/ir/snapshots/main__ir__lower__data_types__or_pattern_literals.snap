fn classify(v0: Int) -> String =
  let v3: Bool = eq_int(v0, 1)
  if v3 {
    "small"
  } else {
    let v2: Bool = eq_int(v0, 2)
    if v2 {
      "small"
    } else {
      let v1: Bool = eq_int(v0, 3)
      if v1 {
        "small"
      } else {
        "big"
      }
    }
  }

fn main() -> Unit =
  let v4: String = call classify(1)
  let v5: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v6: Unit = call println(v5, v4)
  let v7: String = call classify(2)
  let v8: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v9: Unit = call println(v8, v7)
  let v10: String = call classify(3)
  let v11: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v12: Unit = call println(v11, v10)
  let v14: String = call classify(99)
  let v13: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v15: Unit = call println(v13, v14)
