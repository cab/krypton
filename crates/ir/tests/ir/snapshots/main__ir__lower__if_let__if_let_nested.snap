declare println: (g) -> Unit

fn extract(v0: Option[(Int, Int)]) -> String =
  switch v0 {
    0 (v1: a) ->
      let v2: Int = tuple_project v1.0
      let v3: Int = tuple_project v1.1
      let v4: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v5: String = trait_call core/show.Show.show(v4, v3)
      let v6: String = concat_string("inner: ", v5)
      v6
    _ ->
      "none"
  }

fn main() -> Unit =
  let v8: (Int, Int) = tuple(3, 5)
  let v9: Option[(Int, Int)] = construct Option::Some#0(v8)
  let v10: String = call extract(v9)
  let v7: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v11: Unit = call println(v7, v10)
  v11
