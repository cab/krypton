declare println: (h) -> Unit

fn unwrap_or(v0: Option[p8], v1: p8) -> p8 =
  switch v0 {
    0 ->
      v1
    1 (v2: p8) ->
      v2
  }

fn main() -> Unit =
  let v4: Option[s8] = construct Option::None#0()
  let v3: Option[s8] = v4
  let v5: Option[Int] = construct Option::Some#1(42)
  let v6: Int = call unwrap_or(v5, 0)
  let v7: Int = call unwrap_or(v3, v6)
  let v8: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v9: Unit = call println(v8, v7)
  v9
