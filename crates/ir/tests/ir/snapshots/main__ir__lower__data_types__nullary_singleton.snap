fn unwrap_or(v0: Option[h11], v1: h11) -> h11 =
  switch v0 {
    0 ->
      v1
    1 (v2: h11) ->
      v2
  }

fn main() -> Unit =
  let v4: Option[k11] = construct Option::None#0()
  let v3: Option[k11] = v4
  let v5: Option[Int] = construct Option::Some#1(42)
  let v6: Int = call unwrap_or(v5, 0)
