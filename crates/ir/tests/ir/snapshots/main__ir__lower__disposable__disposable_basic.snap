declare println: (o10) -> Unit

fn main() -> Unit =
  let v0: ~Handle = construct Handle::MkHandle#0("test")
  let v1: Unit = call println("opened")
  let v2: Dict[core/disposable.Disposable, Handle] = get_dict core/disposable.Disposable[Handle]
  auto_close[Handle](v0, dict=v2, null=true)
  v1

fn Disposable$$Handle$$dispose(v3: ~Handle) -> Unit =
  switch v3 {
    0 (v4: String) ->
      let v5: Unit = call println("closed")
      v5
  }
