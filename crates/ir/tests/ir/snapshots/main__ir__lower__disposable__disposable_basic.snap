module disposable__disposable_basic

type Handle = MkHandle#0(String)
instance core/disposable.Disposable[Handle] { dispose=Disposable$$Handle$$dispose }
extern java "krypton.runtime.KryptonIO" println(o10) -> Unit
import core/peek/peek as peek(d) -> d
