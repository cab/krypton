declare println: (g) -> Unit

fn process(v0: Foo) -> Int =
  switch v0 {
    0 (v1: Int) ->
      v1
  }

fn process(v2: Bar) -> Int =
  switch v2 {
    0 (v3: Int) ->
      let v4: Int = mul_int(v3, 2)
      v4
  }

fn process(v5: Gen[Int]) -> Int =
  switch v5 {
    0 (v6: Int) ->
      let v7: Int = add_int(v6, 1)
      v7
  }

fn main() -> Unit =
  let v8: Foo = construct Foo::Foo#0(1)
  let v9: Bar = construct Bar::Bar#0(2)
  let v10: Gen[Int] = construct Gen::Gen#0(3)
  let v12: Int = call process(v8)
  let v13: Int = call process(v9)
  let v14: Int = add_int(v12, v13)
  let v15: Int = call process(v10)
  let v16: Int = add_int(v14, v15)
  let v11: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v17: Unit = call println(v11, v16)
  v17
