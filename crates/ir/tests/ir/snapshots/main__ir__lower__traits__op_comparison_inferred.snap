fn main() -> Unit =
  let v5: Dict[core/eq.Eq, Int] = get_dict core/eq.Eq[Int]
  let v6: Bool = call is_equal(v5, 1, 1)
  let v7: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
  let v8: String = trait_call core/show.Show.show(v7, v6)
  let v4: Dict[core/show.Show, String] = get_dict core/show.Show[String]
