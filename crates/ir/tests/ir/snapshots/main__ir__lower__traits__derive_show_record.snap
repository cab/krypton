module traits__derive_show_record

struct Point { x: Int, y: Int }
instance core/show.Show[Point] { show=Show$$Point$$show }
import core/option/Some as Some(b) -> Option[b]
import core/result/Ok as Ok(d) -> Result[c, d]
import core/result/Err as Err(c) -> Result[c, d]
import core/list/Cons as Cons(e, List[e]) -> List[e]
import core/peek/peek as peek(d) -> d
import core/list/last as last(List[e3]) -> Option[e3]
import core/list/sort_by as sort_by(List[j5], (j5) -> y4) -> List[j5]
import core/list/filter as filter(List[h1], (h1) -> Bool) -> List[h1]
import core/vec/to_list as to_list(Vec[w10]) -> List[w10]
import core/traversable/sequence as sequence(o[p[r]]) -> p[o[r]]
import core/io/println as println(g) -> Unit
declare println: (g) -> Unit

fn main() -> Unit =
  let v1: Point = construct Point(1, 2)
  let v2: Dict[core/show.Show, Point] = get_dict core/show.Show[Point]
  let v3: String = trait_call core/show.Show.show(v2, v1)
  let v0: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v4: Unit = call println(v0, v3)
  v4

fn Show$$Point$$show(v5: Point) -> String =
  let v6: Int = project v5.0
  let v7: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v8: String = trait_call core/show.Show.show(v7, v6)
  let v9: String = concat_string("Point(", v8)
  let v10: String = concat_string(v9, ", ")
  let v11: Int = project v5.1
  let v12: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v13: String = trait_call core/show.Show.show(v12, v11)
  let v14: String = concat_string(v10, v13)
  let v15: String = concat_string(v14, ")")
  v15
