fn both_less(v0: Dict[core/ord.Ord, m12], v1: Dict[core/ord.Ord, n12], v2: m12, v3: m12, v4: n12, v5: n12) -> Bool =
  let_join v13(v6: Bool) =
    let_join v12(v8: Bool) =
      let_join v11(v10: Bool) =
        if v10 {
          v8
        } else {
          false
        }
      in
      jump v11(v6)
    in
    let v9: Bool = trait_call core/ord.Ord.lt(v1, v4, v5)
    jump v12(v9)
  in
  let v7: Bool = trait_call core/ord.Ord.lt(v0, v2, v3)
  jump v13(v7)

fn main() -> Unit =
  let v15: Dict[core/ord.Ord, Int] = get_dict core/ord.Ord[Int]
  let v16: Dict[core/ord.Ord, Float] = get_dict core/ord.Ord[Float]
  let v17: Bool = call both_less(v15, v16, 1, 2, 3.0, 4.0)
  let v18: Dict[core/show.Show, Bool] = get_dict core/show.Show[Bool]
  let v19: String = trait_call core/show.Show.show(v18, v17)
  let v14: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v20: Unit = call println(v14, v19)
  v20
