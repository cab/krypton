fn both_less(v0: Dict[core/ord.Ord, l8], v1: Dict[core/ord.Ord, m8], v2: l8, v3: l8, v4: m8, v5: m8) -> Bool =
  let_join v13(v6: Bool) =
    let_join v12(v8: Bool) =
      let_join v11(v10: Bool) =
        if v10 {
          v8
        } else {
          false
        }
      in
      jump v11(v6)
    in
    let v9: Bool = trait_call core/ord.Ord.lt(v1, v4, v5)
    jump v12(v9)
  in
  let v7: Bool = trait_call core/ord.Ord.lt(v0, v2, v3)
  jump v13(v7)

fn main() -> Unit =
  let v15: Dict[core/ord.Ord, Int] = get_dict core/ord.Ord[Int]
  let v16: Dict[core/ord.Ord, Float] = get_dict core/ord.Ord[Float]
