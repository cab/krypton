module stdlib__map_basic

import core/peek/peek as peek(e) -> e
import core/list/last as last(List[q3]) -> Option[q3]
import core/list/sort_by as sort_by(List[v5], (v5) -> k5) -> List[v5]
import core/list/filter as filter(List[g1], (g1) -> Bool) -> List[g1]
import core/list/fold as fold(List[t1], v1, (v1, t1) -> v1) -> v1
import core/list/map as map(List[v], (v) -> x) -> List[x]
import core/vec/to_list as to_list(Vec[y7]) -> List[y7]
import core/io/println as println(h) -> Unit
import core/option/Some as Some(c) -> Option[c]
import core/result/Ok as Ok(e) -> Result[d, e]
import core/result/Err as Err(d) -> Result[d, e]
import core/list/Cons as Cons(f, List[f]) -> List[f]
import core/map/empty as empty() -> Map[a9, b9]
import core/map/put as put(Map[j9, k9], j9, k9) -> Map[j9, k9]
import core/map/get as get(Map[n9, z9], n9) -> Option[z9]
declare empty: () -> Map[a9, b9]
declare get: (Map[n9, z9], n9) -> Option[z9]
declare println: (h) -> Unit
declare put: (Map[j9, k9], j9, k9) -> Map[j9, k9]

fn main() -> Unit =
  let v1: Map[String, Int] = call empty()
  let v2: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v3: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v0: Map[String, Int] = call put(v2, v3, v1, "key", 42)
  let v4: Dict[core/eq.Eq, String] = get_dict core/eq.Eq[String]
  let v5: Dict[core/hash.Hash, String] = get_dict core/hash.Hash[String]
  let v6: Option[Int] = call get(v4, v5, v0, "key")
  switch v6 {
    0 (v7: Int) ->
      let v8: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v9: Unit = call println(v8, v7)
      v9
    1 ->
      let v10: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
      let v11: Unit = call println(v10, 0)
      v11
  }
