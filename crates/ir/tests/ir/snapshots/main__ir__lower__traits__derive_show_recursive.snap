import core/option/Some as Some(b) -> Option[b]
import core/result/Ok as Ok(d) -> Result[c, d]
import core/result/Err as Err(c) -> Result[c, d]
import core/list/Cons as Cons(e, List[e]) -> List[e]
declare println: (g) -> Unit

fn main() -> Unit =
  let v1: List[Int] = construct List::Nil#1()
  let v2: List[Int] = construct List::Cons#0(3, v1)
  let v3: List[Int] = construct List::Cons#0(2, v2)
  let v4: List[Int] = construct List::Cons#0(1, v3)
  let v5: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v6: Dict[core/show.Show, List[Int]] = make_dict core/show.Show[List[Int]](v5)
  let v7: String = trait_call core/show.Show.show(v6, v4)
  let v0: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v8: Unit = call println(v0, v7)
  v8

fn Show$$List$$show(v9: Dict[core/show.Show, b12], v10: List[b12]) -> String =
  switch v10 {
    0 (v11: b12, v12: List[b12]) ->
      let v13: String = trait_call core/show.Show.show(v9, v11)
      let v14: String = concat_string("Cons(", v13)
      let v15: String = concat_string(v14, ", ")
      let v16: Dict[core/show.Show, List[b12]] = make_dict core/show.Show[List[b12]](v9)
      let v17: String = trait_call core/show.Show.show(v16, v12)
      let v18: String = concat_string(v15, v17)
      let v19: String = concat_string(v18, ")")
      v19
    1 ->
      "Nil"
  }
