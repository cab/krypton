fn classify(v0: Int) -> String =
  let_join [recur] v1(v2: Int) =
    let v5: Bool = eq_int(v2, 0)
    if v5 {
      "zero"
    } else {
      let v4: Bool = eq_int(v2, 1)
      if v4 {
        "one"
      } else {
        let v3: Int = sub_int(v2, 1)
        jump v1(v3)
      }
    }
  in
  jump v1(v0)
