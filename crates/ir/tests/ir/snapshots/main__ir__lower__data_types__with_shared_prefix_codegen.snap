declare println: (g) -> Unit

fn main() -> Unit =
  let v1: City = construct City(0, 0)
  let v2: Addr = construct Addr(v1)
  let v0: User = construct User(v2)
  let_join v24(v3: User) =
    let v14: Addr = project v3.0
    let v15: City = project v14.0
    let v16: Int = project v15.0
    let v17: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
    let v18: Unit = call println(v17, v16)
    let v20: Addr = project v3.0
    let v21: City = project v20.0
    let v22: Int = project v21.1
    let v19: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
    let v23: Unit = call println(v19, v22)
    v23
  in
  let_join v13(v11: Addr) =
    let v12: User = construct User(v11)
    jump v24(v12)
  in
  let v4: Addr = project v0.0
  let_join v10(v8: City) =
    let v9: Addr = construct Addr(v8)
    jump v13(v9)
  in
  let v5: Addr = project v0.0
  let v6: City = project v5.0
  let v7: City = construct City(94103, 7)
  jump v10(v7)
