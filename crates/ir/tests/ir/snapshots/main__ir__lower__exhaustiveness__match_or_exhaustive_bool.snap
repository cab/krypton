fn test(v0: Bool, v1: Bool) -> Int =
  let v2: (Bool, Bool) = tuple(v0, v1)
  let v3: Bool = tuple_project v2.0
  let v4: Bool = tuple_project v2.1
  let v9: Bool = eq_int(v3, true)
  if v9 {
    1
  } else {
    let v8: Bool = eq_int(v3, false)
    if v8 {
      let v7: Bool = eq_int(v4, true)
      if v7 {
        1
      } else {
        let v6: Bool = eq_int(v4, false)
        if v6 {
          2
        } else {
          ()
        }
      }
    } else {
      let v5: Bool = eq_int(v4, true)
      if v5 {
        1
      } else {
        ()
      }
    }
  }
