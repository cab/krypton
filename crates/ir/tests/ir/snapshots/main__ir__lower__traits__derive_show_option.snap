fn main() -> Unit =
  let v1: Option[Int] = construct Option::Some#0(42)
  let v2: Dict[core/show.Show, Int] = get_dict core/show.Show[Int]
  let v3: Dict[core/show.Show, Option[Int]] = make_dict core/show.Show[Option[Int]](v2)
  let v4: String = trait_call core/show.Show.show(v3, v1)
  let v0: Dict[core/show.Show, String] = get_dict core/show.Show[String]
  let v5: Unit = call println(v0, v4)
  v5

fn Show$$Option$$show(v6: Dict[core/show.Show, b12], v7: Option[b12]) -> String =
  switch v7 {
    0 (v8: b12) ->
      let v9: String = trait_call core/show.Show.show(v6, v8)
      let v10: String = concat_string("Some(", v9)
      let v11: String = concat_string(v10, ")")
      v11
    1 ->
