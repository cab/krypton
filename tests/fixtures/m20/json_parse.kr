# expect: output "JObj"
import core/list.{Cons, Nil}
import core/result.{Ok, Err}
import core/json.{parse_json, json_to_string, json_object, Json, JObj, JNum}
fun main() = {
  let j = json_object(Cons(("a", JNum(1.0)), Nil))
  let s = json_to_string(j)
  match parse_json(s) {
    Ok(JObj(m)) => println("JObj"),
    _ => println("FAIL"),
  }
}
