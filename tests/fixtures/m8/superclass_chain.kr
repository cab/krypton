# expect: output true
extern "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type Num = { n: Int }

trait Eq[a] {
    fun eq(_0: a, _1: a) -> Bool
}

impl Eq[Num] {
    fun eq(a, b) = a.n == b.n
}

trait Ord[a] where a: Eq {
    fun lt(_0: a, _1: a) -> Bool
}

impl Ord[Num] {
    fun lt(a, b) = a.n < b.n
}

fun is_less(x, y) = lt(x, y)

fun main() = println(is_less(Num(1), Num(2)))
