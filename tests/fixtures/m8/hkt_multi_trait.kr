# expect: ok
type Box[a] = Box(a)

trait Functor[f[_]] {
  fun fmap[a, b](fa: f[a], g: (a) -> b) -> f[b]
}

trait Container[f[_]] {
  fun wrap[a](x: a) -> f[a]
}

impl Functor[Box] {
  fun fmap[a, b](fa: Box[a], g: (a) -> b) -> Box[b] =
    match fa { Box(x) => Box(g(x)) }
}

impl Container[Box] {
  fun wrap[a](x: a) -> Box[a] = Box(x)
}
