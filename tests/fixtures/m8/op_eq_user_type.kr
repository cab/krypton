# expect: output true
(extern "krypton.runtime.KryptonIO" (def println [Object] Unit))
(type Point (record (x Int) (y Int)))
(trait Eq [a] (def eq [a a] Bool))
(impl Eq Point
  (def eq [a b] (if (== (. a x) (. b x)) (== (. a y) (. b y)) false)))
(def main (fn [] (println (eq (Point 1 2) (Point 1 2)))))
