# expect: output true
extern "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type Wrapper = { val: Int }

trait Eq[a] {
    fun eq(_0: a, _1: a) -> Bool
}

impl Eq[Wrapper] {
    fun eq(a, b) = a.val == b.val
}

trait Ord[a] where a: Eq {
    fun lt(_0: a, _1: a) -> Bool
}

impl Ord[Wrapper] {
    fun lt(a, b) = a.val < b.val
}

fun main() = println(lt(Wrapper(1), Wrapper(2)))
