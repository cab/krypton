# expect: output true
extern "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type Box = { val: Int }

trait Eq[a] {
    fun eq(_0: a, _1: a) -> Bool
}

impl Eq[Box] {
    fun eq(a, b) = a.val == b.val
}

trait Show[a] {
    fun show(_0: a) -> String
}

impl Show[Box] {
    fun show(a) = "Box"
}

fun eq_and_show(x, y) = if eq(x, y) { show(x) } else { "not equal" }

fun main() = println(eq_and_show(Box(1), Box(1)) == "Box")
