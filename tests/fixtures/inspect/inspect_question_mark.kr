extern java "krypton.runtime.KryptonIO" { fun println[a](x: a) -> Unit }

type Handle = MkHandle(String)

impl Disposable[Handle] {
    fun dispose(h: ~Handle) -> Unit = match h {
        MkHandle(_) => println("closed"),
    }
}

fun fallible() -> Result[String, Int] = Err("fail")

fun work() -> Result[String, Int] = {
    let h: ~Handle = MkHandle("test")
    println("opened")
    let x = fallible()?;
    Ok(x)
}

fun main() = match work() {
    Ok(v) => println(v),
    Err(e) => println("err"),
}
