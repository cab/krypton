# expect: output "true"
extern java "krypton.runtime.KryptonIO" {
    fun println[a](x: a) -> Unit
}

fun main() -> Unit = {
  # && truth table
  let a1 = true && true    # true
  let a2 = true && false   # false
  let a3 = false && true   # false
  let a4 = false && false  # false

  # || truth table
  let o1 = true || true    # true
  let o2 = true || false   # true
  let o3 = false || true   # true
  let o4 = false || false  # false

  # ! operator
  let n1 = !true   # false
  let n2 = !false  # true

  # Combined expression
  let c1 = true && false || !false  # true

  # Verify all results
  let ok = a1 && !a2 && !a3 && !a4 && o1 && o2 && o3 && !o4 && !n1 && n2 && c1

  println(ok)
}
