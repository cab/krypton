# expect: output "42"
extern "krypton.runtime.KryptonIO" { fun println(Object) -> Unit }
fun parse(x) -> Result[String, Int] = Ok(x)
fun double(x) -> Result[String, Int] = Ok(x * 2)
fun process(x) -> Result[String, Int] = {
  let a = parse(x)?;
  let b = double(a)?;
  Ok(b)
}
fun main() = match process(21) {
  Ok(v) => println(v),
  Err(e) => println(e),
}
