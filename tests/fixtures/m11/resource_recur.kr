# expect: output "iter\nclosed\niter\nclosed\niter\nclosed\ndone"
extern "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type Handle = MkHandle(Int)

trait Resource[a] {
    fun close(x: ~a) -> Unit
}

impl Resource[Handle] {
    fun close(h: ~Handle) -> Unit = println("closed")
}

fun loop(n: Int) -> Unit =
    if n >= 3 { println("done") }
    else {
        let h: ~Handle = MkHandle(n)
        println("iter")
        recur(n + 1)
    }

fun main() -> Unit = loop(0)
