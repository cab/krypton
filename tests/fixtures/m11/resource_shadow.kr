# expect: output "open1\nclosed\nopen2\nclosed"
extern "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type Handle = MkHandle(String)

trait Resource[a] {
    fun close(x: ~a) -> Unit
}

impl Resource[Handle] {
    fun close(h: ~Handle) -> Unit = println("closed")
}

fun main() -> Unit = {
    let h: ~Handle = MkHandle("1")
    println("open1")
    let h: ~Handle = MkHandle("2")
    println("open2")
}
