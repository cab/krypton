# expect: output "opened\nmanual_close"
extern "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type Handle = MkHandle(String)

trait Resource[a] {
    fun close(x: ~a) -> Unit
}

impl Resource[Handle] {
    fun close(h: ~Handle) -> Unit = println("manual_close")
}

fun main() -> Unit = {
    let h: ~Handle = MkHandle("test")
    println("opened")
    close(h)
}
