# expect: output "49995000"
# Cross-thread Vec publication: parent builds a 10_000-element Vec[Int] and
# sends it to a spawned child. The child folds to sum 0..9999 and replies.
# Primary purpose is the JVM safe-publication regression: the persistent-vec
# rewrite stores the backing data in a final field so the JMM's §17.5 final-
# field guarantee covers the cross-thread publication. JS passes trivially
# (single-threaded event loop; send is a no-op memory barrier).
import core/actor.{Mailbox, Ref, spawn, send, receive, actor_ref, mailbox}
import core/vec.{push, fold}

type Msg = VecMsg(Vec[Int], Ref[Int])

fun build_vec(v: Vec[Int], i: Int, n: Int) -> Vec[Int] =
    if i < n { recur(push(v, i), i + 1, n) } else { v }

fun worker(mb: Mailbox[Msg]) =
    match receive(mb) {
        VecMsg(v, sender) => send(sender, fold(v, 0, (acc, x) -> acc + x)),
    }

fun main() -> Unit = {
    let target = spawn(worker);
    let my_mb: Mailbox[Int] = mailbox();
    let v = build_vec([], 0, 10000);
    send(target, VecMsg(v, actor_ref(my_mb)));
    println(receive(my_mb))
}
