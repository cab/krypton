# expect: output 42
extern java "krypton.runtime.KryptonIO" {
    fun println[a](x: a) -> Unit
}
import core/actor.{Mailbox, Ref, spawn, send, receive, actor_ref, mailbox}

type Msg = Ping(Int, Ref[Int])

fun echo(mb: Mailbox[Msg]) =
  match receive(mb) {
    Ping(n, sender) => send(sender, n),
  }

fun main() {
  let target = spawn(echo)
  let my_mb: Mailbox[Int] = mailbox()
  send(target, Ping(42, actor_ref(my_mb)))
  let result = receive(my_mb)
  println(result)
}
