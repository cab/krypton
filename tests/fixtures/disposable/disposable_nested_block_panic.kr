# skip: js(java-only extern)
# expect: panic "boom"
# expect: output "open_a\nopen_b\nclose_b\nclose_a"
extern java "krypton.runtime.KryptonIO" {
    fun println[a](x: a) -> Unit
}

type HandleA = MkHandleA(Int)
type HandleB = MkHandleB(Int)

impl Disposable[HandleA] {
    fun dispose(h: ~HandleA) -> Unit = println("close_a")
}

impl Disposable[HandleB] {
    fun dispose(h: ~HandleB) -> Unit = println("close_b")
}

fun main() -> Unit = {
    let a: ~HandleA = MkHandleA(1)
    println("open_a")
    {
        let b: ~HandleB = MkHandleB(2)
        println("open_b")
        panic("boom")
    }
}
