# expect: ok
# expect: output "6"
# Split out from map_vec_accessors — having fold(values) and fold(entries)
# in the same module currently triggers a trait-dispatch inference bug where
# the tuple element type corrupts the value element type inference. Filed as
# a follow-up; for now this fixture exercises fold over entries in isolation.
import core/map.{Map, empty, put, entries}
import core/foldable.{fold}

fun add_pair_val(acc: Int, pair: (String, Int)) -> Int = {
    let (_, v) = pair
    acc + v
}

fun main() = {
  let m: Map[String, Int] = put(put(put(empty(), "a", 1), "b", 2), "c", 3);
  println(fold(entries(m), 0, add_pair_val))
}
