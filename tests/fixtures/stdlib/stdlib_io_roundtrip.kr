# expect: output "hello from file"
import core/io.{read_file, write_file}
extern java "krypton.runtime.KryptonIO" { fun println[a](a) -> Unit }

fun handle(r) = match r {
    Ok(content) => println(content),
    Err(e) => println(e),
}

fun main() {
    let _ = write_file("_test_tmp.txt", "hello from file");
    handle(read_file("_test_tmp.txt"))
}
