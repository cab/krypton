# expect: ok
# expect: output "3\n42"
import core/map.{Map, builder, put, freeze, get, size}

fun main() = {
  let b = builder();
  let b2 = put(b, "a", 1);
  let b3 = put(b2, "b", 2);
  let b4 = put(b3, "answer", 42);
  let m = freeze(b4);
  println(size(m));
  match get(m, "answer") {
    Some(v) => println(v),
    None => println(0),
  }
}
