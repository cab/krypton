# expect: ok
fun fold[A, B](xs: List[A], acc: B, f: (B, A) -> B) -> B =
    match xs { Nil => acc, Cons(h, rest) => fold(rest, f(acc, h), f) }

fun test() -> ~Option[Int] =
    fold[Int, ~Option[Int]](
        Cons(1, Nil),
        Some(0),
        (acc, x) -> match acc {
            Some(_) => Some(x),
            None => Some(x),
        }
    )
