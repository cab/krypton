# expect: ok
# Reading a plain-data field from a borrow of a resource-carrying record
# must succeed: the borrow observes the record without consuming it.
# Replaces the pre-M39-T6 shared-coerce-of-bare-`Task` test.
extern java "net.Sock" as pub Sock lifts always {}
extern js "net.mjs" as pub Sock lifts always {}
type Task = { sock: ~Sock, timeout: Int }
fun get_timeout(&t: ~Task) -> Int = t.timeout
