# expect: error E0109
# Pre-M39-T6, bare `Task` in a param position was accepted and the `~Int`
# field was coerced to `Int`. M39-T6 rejects the bare spelling at the
# annotation site — the user must write `~Task` or borrow via `&t: ~Task`.
type Config = { timeout: ~Int }
type Task = { config: ~Config }
fun get_timeout(t: Task) -> Int = t.config.timeout
