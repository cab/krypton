# expect: ok
# Exercises the `~־² ג†’ ־²` silent self-reference arm in `coerce_unify`.
# Instantiating `view` at call site produces a fresh `־±` that appears in
# both the `~־±` parameter slot and the `־±` return slot; passing an owned
# value must succeed without triggering occurs-check on `־² := Own(Var(־²))`.
fun view[t](x: ~t) -> t = x
fun test(s: ~String) -> String = view(s)
