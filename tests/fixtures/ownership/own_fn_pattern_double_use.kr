# expect: error E0101
type Wrapper = { action: ~() -> String }
fun consume(buf: ~String) -> String = match buf { _ => "" }
fun test(x: ~String) -> String {
    let w: ~Wrapper = Wrapper { action = () -> consume(x) }
    match w {
        Wrapper { action } => {
            action()
            action()
        }
    }
}
