# expect: error E0104
# Owned closure passed to recur-based loop: f is used twice per iteration (RequiresU)
fun repeat(f, n: Int) -> String =
    if n == 0 { "done" }
    else { f(n); recur(f, n - 1) }

fun consume(buf: ~String) -> String = match buf { _ => "" }

fun test(s: ~String) -> String = repeat(x -> consume(s), 3)
