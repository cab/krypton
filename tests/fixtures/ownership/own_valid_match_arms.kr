# expect: ok
# All-owned match arms preserve ownership through pair-wise joining
type Color = Red | Green | Blue

fun consume(buf: ~Option[Int]) -> Option[Int] = match buf {
    Some(n) => Some(n),
    None => None,
}

fun test(c: Color) -> Option[Int] =
    consume(match c {
        Red => Some(1),
        Green => Some(2),
        Blue => Some(3),
    })
