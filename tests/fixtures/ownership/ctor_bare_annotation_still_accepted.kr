# expect: ok
# M42-T7 pins current behavior: when the user writes a bare annotation on a
# resource-carrying type (`let c: Conn = ...`), T7 does NOT auto-wrap — it
# leaves the bare result so the existing unify path succeeds. M39-T6 will
# later turn this into E0109 BareUseOfResourceType at the binding site.

extern java "net.Socket" as pub Socket lifts always {}
extern js "net.mjs"     as pub Socket lifts always {}

type Conn = { sock: ~Socket, name: String }

fun mk(s: ~Socket) -> Conn = {
  let c: Conn = Conn { sock = s, name = "foo" }
  c
}
