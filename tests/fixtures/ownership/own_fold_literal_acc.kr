# expect: ok
# fold with literal accumulator — the key pattern option 3 preserves
fun fold[A, B](xs: List[A], acc: B, f: (B, A) -> B) -> B =
    match xs {
        Nil => acc,
        Cons(h, rest) => fold(rest, f(acc, h), f),
    }
fun test() -> Int = fold(Cons(1, Cons(2, Cons(3, Nil))), 0, (acc, x) -> acc + x)
