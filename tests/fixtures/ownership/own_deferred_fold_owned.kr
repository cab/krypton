# expect: ok
# fold with owned return — MaybeOwn qualifier confirmed Affine by ~T annotation
fun fold[A, B](xs: List[A], acc: B, f: (B, A) -> B) -> B =
    match xs {
        Nil => acc,
        Cons(h, rest) => fold(rest, f(acc, h), f),
    }
fun test() -> ~Option[Int] =
    fold(Cons(1, Cons(2, Cons(3, Nil))), Some(0), (acc, x) -> Some(x))
