# expect: error E0101
# `consume` infers T = String for `a`; using `a` again is a double-use error.
fun consume[T](x: ~T) -> Int = match x { _ => 0 }
fun consume_string(x: ~String) -> Int = match x { _ => 0 }

fun test(a: ~String) -> Int {
    let x = consume(a)
    let y = consume_string(a)
    y
}
