# expect: output true
extern java "krypton.runtime.KryptonIO" {
    fun println[a](x: a) -> Unit
}

type Point = { x: Int, y: Int }

impl Eq[Point] {
    fun eq(x, y) = if x.x == y.x { x.y == y.y } else { false }
}

fun are_equal[a](x: a, y: a) -> Bool where a: Eq = eq(x, y)

fun main() = println(are_equal(Point(1, 2), Point(1, 2)))
