# expect: error E0312

trait Default[a] {
    fun default() -> a
}

impl Default[Int] {
    fun default() = 0
}

trait R[f[_]] {
    fun lol[b](a: f[b]) -> f[b] where b: Default
}

impl R[List] {
    fun lol[b](a: List[b]) -> List[b] where b: Default = Cons(default(), a)
}

fun broken[a](xs: List[a]) -> List[a] = xs.lol()
