# expect: ok
type Box[a] = Box(a)

trait Functor[f[_]] {
  fun fmap[a, b](fa: f[a], g: (a) -> b) -> f[b]
}

impl Functor[Box] {
  fun fmap[a, b](fa: Box[a], g: (a) -> b) -> Box[b] =
    match fa { Box(x) => Box(g(x)) }
}

fun main() -> Unit {
  let b = Box(42)
  let b2 = fmap(b, x -> x + 1)
  println(match b2 { Box(n) => n })
}
