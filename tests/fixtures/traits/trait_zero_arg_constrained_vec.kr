# expect: output "yo"
extern java "krypton.runtime.KryptonIO" {
    fun println[a](x: a) -> Unit
}

trait Test[e] {
    fun name() -> String
}

impl[a] Test[Vec[a]] where a: Test {
    fun name() = name[a]()
}

impl Test[Int] {
    fun name() = "yo"
}

fun main() = {
    println(name[Vec[Int]]())
}
