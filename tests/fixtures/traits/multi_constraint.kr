# expect: output true
extern java "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type Box = { val: Int }

impl Eq[Box] {
    fun eq(a, b) = a.val == b.val
}

impl Show[Box] {
    fun show(a) = "Box"
}

fun eq_and_show[a](x: a, y: a) -> String where a: Eq + Show = if eq(x, y) { show(x) } else { "not equal" }

fun main() = println(eq_and_show(Box(1), Box(1)) == "Box")
