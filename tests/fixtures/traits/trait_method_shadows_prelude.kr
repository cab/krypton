# expect: ok
# expect: output "6\n3"
import core/show.{Show, show}
extern java "krypton.runtime.KryptonIO" {
    fun println[a](a) -> Unit
}

trait Multiply[a] {
    fun times(x: a, y: a) -> a
}
impl Multiply[Int] {
    fun times(x: Int, y: Int) -> Int = x * y
}
fun main() -> Unit = {
    println(show(times(2, 3)))
    println(show(1 + 2))
}
