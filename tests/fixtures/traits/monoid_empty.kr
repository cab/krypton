# expect: output "0\n1\n0"
extern java "krypton.runtime.KryptonIO" {
    fun println[a](a) -> Unit
}

trait Monoid[a] {
    fun empty() -> a
    fun combine(_0: a, _1: a) -> a
}

impl Monoid[Int] {
    fun empty() = 0
    fun combine(x, y) = x + y
}

# Use a thunk to exercise trait method as value (not just call head)
fun apply_thunk(f: () -> Int) -> Int = f()

fun main() {
    println(empty[Int]())
    println(combine(empty[Int](), 1))
    println(apply_thunk(empty[Int]))
}
