# expect: output true
extern "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type Num = { n: Int }

impl Eq[Num] {
    fun eq(a, b) = a.n == b.n
}

impl Ord[Num] {
    fun lt(a, b) = a.n < b.n
}

fun is_less[a](x: a, y: a) -> Bool where a: Ord = lt(x, y)

fun main() = println(is_less(Num(1), Num(2)))
