# expect: output "42\nMyStruct"
extern "krypton.runtime.KryptonIO" {
    fun println(Object) -> Unit
}

type MyStruct = MyStruct(Int) deriving (Show)

trait Default[a] {
    fun default() -> a
}

impl Default[Int] {
    fun default() = 42
}

impl Default[MyStruct] {
    fun default() = MyStruct(10)
}

fun main() {
    println(default[Int]());
    println(default[MyStruct]())
}
