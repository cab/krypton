# expect: ok
# Inside a Disposable dispose impl, the `self` parameter is classified as
# Linear (not Disposable), so auto-close does not recursively insert a
# dispose(self) call. The body must still explicitly discharge the self
# obligation — here by destructuring via pattern match.
type Foo = MkFoo(Int)

impl Disposable[Foo] {
    fun dispose(f: ~Foo) -> Unit = match f {
        MkFoo(_) => (),
    }
}
