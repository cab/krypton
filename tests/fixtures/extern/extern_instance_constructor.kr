# skip: js(java-only extern)
# expect: output "hello from bridge"
extern java "java.lang.Runnable" as trait Runnable[a] {
  fun run(this: a) -> Unit
}
impl Runnable[() -> Unit] {
  fun run(f) = f()
}
extern java "java.lang.Thread" as JThread {
  @constructor fun new[a](target: a) -> ~JThread where a: Runnable
  @instance fun start(self: JThread) -> Unit
}
fun main() = {
  let t = new(() -> println("hello from bridge"))
  start(t)
}
