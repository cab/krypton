# skip: js(java-only extern)
# Regression: two `let h = Handle::new()` in the SAME block scope with a
# panic after the second. The first binding must be closed exactly once
# by the shadow_close path (which nulls its slot), so the function-wide
# finally handler sees only the second binding on unwind — not both.
# expect: panic "boom"
# expect: output "open1\nclose1\nopen2\nclose2"
extern java "krypton.runtime.KryptonIO" {
    fun println[a](x: a) -> Unit
}

type H1 = MkH1
type H2 = MkH2

impl Resource[H1] {
    fun close(h: ~H1) -> Unit = println("close1")
}

impl Resource[H2] {
    fun close(h: ~H2) -> Unit = println("close2")
}

fun main() -> Unit = {
    let h: ~H1 = MkH1
    println("open1")
    let h: ~H2 = MkH2
    println("open2")
    panic("boom")
}
