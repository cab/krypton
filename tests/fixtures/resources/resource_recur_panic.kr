# skip: js(java-only extern)
# Regression: recur back-edge must null resource slots before jumping,
# so an exception during a later iteration doesn't make the function-wide
# finally handler double-close the previous iteration's (already closed)
# resource. Each iteration closes its own `h` on the back-edge; the final
# (panicking) iteration's `h` is closed by the fn-wide handler — exactly
# once. Three iterations ⇒ three `closed` lines total (not four).
# expect: panic "boom"
# expect: output "iter0\nclosed\niter1\nclosed\nboom_iter\nclosed"
extern java "krypton.runtime.KryptonIO" {
    fun println[a](x: a) -> Unit
}

type Handle = MkHandle(Int)

impl Resource[Handle] {
    fun close(h: ~Handle) -> Unit = println("closed")
}

fun loop(n: Int) -> Unit = {
    let h: ~Handle = MkHandle(n)
    if n == 0 {
        println("iter0")
        recur(1)
    }
    else {
        if n == 1 {
            println("iter1")
            recur(2)
        }
        else {
            println("boom_iter")
            panic("boom")
        }
    }
}

fun main() -> Unit = loop(0)
