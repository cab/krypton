{
  "scripts": {
    "build:frontend": "esbuild frontend/tour.js frontend/playground-worker.js --bundle --format=esm --sourcemap --outdir=generated --external:/static/compiler/*",
    "build:playground-wasm": "wasm-pack build ../crates/playground --target web --dev --out-dir ../../book/generated/compiler --out-name krypton_playground",
    "build:playground-wasm:release": "wasm-pack build ../crates/playground --target web --release  --out-dir ../../book/generated/compiler --out-name krypton_playground"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "codemirror": "^6.0.2",
    "esbuild": "^0.27.4"
  }
}
