type Connection = Connection(String)

impl Resource[Connection] {
  fun close(conn: ~Connection) -> Unit = match conn {
    Connection(name) => println("closing " + name),
  }
}

fun send_request(conn: ~Connection) -> Result[String, String] =
  Ok("ok from server")

fun main() {
  let conn = Connection("chat-db")
  println(send_request(conn))
}
