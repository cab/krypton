type Box[a] = Box(a)

trait Functor[f[_]] {
  fun fmap[a, b](fa: f[a], g: (a) -> b) -> f[b]
}

impl Functor[Box] {
  fun fmap[a, b](fa: Box[a], g: (a) -> b) -> Box[b] = match fa {
    Box(value) => Box(g(value)),
  }
}

fun relabel[f[_], a](fa: f[a]) -> f[String] where f: Functor, a: Show =
  fmap(fa, value -> "value: " + show(value))

fun unbox[a](box: Box[a]) -> a = match box {
  Box(value) => value,
}

fun main() {
  println(unbox(relabel(Box(5))))
}
