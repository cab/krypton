# Compiler intrinsic: primitive instance bodies are replaced by optimized JVM
# bytecode (lmul, dmul) at codegen time. The __krypton_intrinsic() marker tells
# the compiler to skip body type-checking and use bridge bytecode instead.
pub trait Mul[a] {
    fun mul(self: a, other: a) -> a
}
impl Mul[Int] { fun mul(a: Int, b: Int) -> Int = __krypton_intrinsic() }
impl Mul[Float] { fun mul(a: Float, b: Float) -> Float = __krypton_intrinsic() }
