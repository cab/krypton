# Compiler intrinsic: primitive instance bodies are replaced by optimized JVM
# bytecode (ldiv, ddiv) at codegen time. The __krypton_intrinsic() marker tells
# the compiler to skip body type-checking and use bridge bytecode instead.
pub trait Div[a] {
    fun div(self: a, other: a) -> a
}
impl Div[Int] { fun div(a: Int, b: Int) -> Int = __krypton_intrinsic() }
impl Div[Float] { fun div(a: Float, b: Float) -> Float = __krypton_intrinsic() }
