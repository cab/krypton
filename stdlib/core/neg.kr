# Compiler intrinsic: primitive instance bodies are replaced by optimized JVM
# bytecode (lneg, dneg) at codegen time. The __krypton_intrinsic() marker tells
# the compiler to skip body type-checking and use bridge bytecode instead.
pub trait Neg[a] {
    fun neg(self: a) -> a
}
impl Neg[Int] { fun neg(a: Int) -> Int = __krypton_intrinsic() }
impl Neg[Float] { fun neg(a: Float) -> Float = __krypton_intrinsic() }
