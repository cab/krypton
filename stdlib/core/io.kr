import core/result.{Result, Ok, Err}
import core/show.{Show}

# core/io — I/O functions
extern "krypton.runtime.KryptonIO" {
    fun raw_println(Object) -> Unit
    fun raw_print(Object) -> Unit
    pub fun readLine() -> String
    pub fun read_file(String) -> Result[String, String]
    pub fun write_file(String, String) -> Result[String, Unit]
}

pub fun println(x) = raw_println(show(x))
pub fun print(x) = raw_print(show(x))
