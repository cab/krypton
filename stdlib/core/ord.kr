import core/eq.{Eq}
# Compiler intrinsic: primitive instance bodies are replaced by optimized JVM
# bytecode (lcmp, dcmpl) at codegen time. The __krypton_intrinsic() marker tells
# the compiler to skip body type-checking and use bridge bytecode instead.
pub trait Ord[a] where a: Eq {
    fun lt(self: a, other: a) -> Bool
}
impl Ord[Int] { fun lt(a: Int, b: Int) -> Bool = __krypton_intrinsic() }
impl Ord[Float] { fun lt(a: Float, b: Float) -> Bool = __krypton_intrinsic() }
