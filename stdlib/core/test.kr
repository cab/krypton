import core/string.{concat}
import core/result.{Result, Ok, Err}
import core/option.{Option, Some, None}

pub fun assert(cond: Bool) -> Unit =
    if cond { () } else { panic("assertion failed: assert") }

pub fun assert_true(cond: Bool) -> Unit =
    if cond { () } else { panic("assertion failed: assert_true") }

pub fun assert_true_msg(cond: Bool, msg: String) -> Unit =
    if cond {
        ()
    } else {
        panic(concat("assertion failed: assert_true\ncontext: ", msg))
    }

pub fun assert_false(cond: Bool) -> Unit =
    if cond { panic("assertion failed: assert_false") } else { () }

pub fun assert_false_msg(cond: Bool, msg: String) -> Unit =
    if cond {
        panic(concat("assertion failed: assert_false\ncontext: ", msg))
    } else {
        ()
    }

pub fun assert_eq[a](left: a, right: a) -> Unit where a: Eq + Show + shared =
    if eq(left, right) {
        ()
    } else {
        panic(concat(
            concat("assertion failed: assert_eq\n  expected: ", show(right)),
            concat("\n  got:      ", show(left))
        ))
    }

pub fun assert_eq_msg[a](left: a, right: a, msg: String) -> Unit
    where a: Eq + Show + shared =
    if eq(left, right) {
        ()
    } else {
        panic(concat(
            concat(
                concat("assertion failed: assert_eq\n  expected: ", show(right)),
                concat("\n  got:      ", show(left))
            ),
            concat("\ncontext: ", msg)
        ))
    }

pub fun assert_neq[a](left: a, right: a) -> Unit where a: Eq + Show + shared =
    if eq(left, right) {
        panic(concat("assertion failed: assert_neq (both equal): ", show(left)))
    } else {
        ()
    }

pub fun assert_neq_msg[a](left: a, right: a, msg: String) -> Unit
    where a: Eq + Show + shared =
    if eq(left, right) {
        panic(concat(
            concat("assertion failed: assert_neq (both equal): ", show(left)),
            concat("\ncontext: ", msg)
        ))
    } else {
        ()
    }

pub fun assert_ok[e, a](r: Result[e, a]) -> a where e: Show + shared = match r {
    Ok(x) => x,
    Err(err) => panic(concat("assertion failed: assert_ok\n  got Err: ", show(err))),
}

pub fun assert_ok_msg[e, a](r: Result[e, a], msg: String) -> a
    where e: Show + shared = match r {
    Ok(x) => x,
    Err(err) => panic(concat(
        concat("assertion failed: assert_ok\n  got Err: ", show(err)),
        concat("\ncontext: ", msg)
    )),
}

pub fun assert_err[e, a](r: Result[e, a]) -> e where a: Show + shared = match r {
    Err(err) => err,
    Ok(x) => panic(concat("assertion failed: assert_err\n  got Ok: ", show(x))),
}

pub fun assert_err_msg[e, a](r: Result[e, a], msg: String) -> e
    where a: Show + shared = match r {
    Err(err) => err,
    Ok(x) => panic(concat(
        concat("assertion failed: assert_err\n  got Ok: ", show(x)),
        concat("\ncontext: ", msg)
    )),
}

pub fun assert_some[a](o: Option[a]) -> a = match o {
    Some(v) => v,
    None => panic("assertion failed: assert_some\n  got None"),
}

pub fun assert_some_msg[a](o: Option[a], msg: String) -> a = match o {
    Some(v) => v,
    None => panic(concat(
        "assertion failed: assert_some\n  got None\ncontext: ",
        msg
    )),
}

pub fun assert_none[a](o: Option[a]) -> Unit where a: Show + shared = match o {
    None => (),
    Some(v) => panic(concat("assertion failed: assert_none\n  got Some: ", show(v))),
}

pub fun assert_none_msg[a](o: Option[a], msg: String) -> Unit
    where a: Show + shared = match o {
    None => (),
    Some(v) => panic(concat(
        concat("assertion failed: assert_none\n  got Some: ", show(v)),
        concat("\ncontext: ", msg)
    )),
}
