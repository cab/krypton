# ── ToJson trait ───────────────────────────────────────────────��─

pub trait ToJson[a] {
    fun to_json(x: a) -> Json
}

impl ToJson[Int] {
    fun to_json(x: Int) -> Json = JNum(toFloat(x))
}

impl ToJson[Float] {
    fun to_json(x: Float) -> Json = JNum(x)
}

impl ToJson[String] {
    fun to_json(x: String) -> Json = JStr(x)
}

impl ToJson[Bool] {
    fun to_json(x: Bool) -> Json = JBool(x)
}

impl ToJson[List[a]] where a: ToJson {
    fun to_json(xs: List[a]) -> Json = JArr(list_map(xs, (x) -> to_json(x)))
}

impl ToJson[Option[a]] where a: ToJson {
    fun to_json(opt: Option[a]) -> Json = match opt {
        None => JNull,
        Some(x) => to_json(x),
    }
}

impl ToJson[Map[String, a]] where a: ToJson {
    fun to_json(m: Map[String, a]) -> Json =
        JObj(from_list(list_map(entries(m), (pair) -> { let (k, v) = pair; (k, to_json(v)) })))
}

# ── FromJson trait ──────────────────���────────────────────────────

pub trait FromJson[a] {
    fun from_json(j: Json) -> Result[String, a]
}

# toInt truncates toward zero (Java `(long)` cast), e.g. 42.9 → 42
impl FromJson[Int] {
    fun from_json(j: Json) -> Result[String, Int] = match j {
        JNum(n) => Ok(toInt(n)),
        _ => Err("expected number"),
    }
}

impl FromJson[Float] {
    fun from_json(j: Json) -> Result[String, Float] = match j {
        JNum(n) => Ok(n),
        _ => Err("expected number"),
    }
}

impl FromJson[String] {
    fun from_json(j: Json) -> Result[String, String] = match j {
        JStr(s) => Ok(s),
        _ => Err("expected string"),
    }
}

impl FromJson[Bool] {
    fun from_json(j: Json) -> Result[String, Bool] = match j {
        JBool(b) => Ok(b),
        _ => Err("expected bool"),
    }
}

fun from_json_list_go[a](remaining: List[Json], acc: List[a]) -> Result[String, List[a]] where a: FromJson =
    match remaining {
        Nil => Ok(reverse(acc)),
        Cons(h, rest) => {
            let r: Result[String, a] = from_json(h);
            match r {
                Err(e) => Err(e),
                Ok(v) => recur(rest, Cons(v, acc)),
            }
        },
    }

fun from_json_list[a](items: List[Json]) -> Result[String, List[a]] where a: FromJson =
    from_json_list_go(items, Nil)

impl FromJson[List[a]] where a: FromJson {
    fun from_json(j: Json) -> Result[String, List[a]] = match j {
        JArr(items) => from_json_list(items),
        _ => Err("expected array"),
    }
}

# Note: for nested Option[Option[a]], JNull always yields Ok(None) for the
# outer layer — Ok(Some(None)) is not representable. This matches Aeson/serde.
impl FromJson[Option[a]] where a: FromJson {
    fun from_json(j: Json) -> Result[String, Option[a]] = match j {
        JNull => Ok(None),
        _ => match from_json(j) {
            Ok(v) => Ok(Some(v)),
            Err(e) => Err(e),
        },
    }
}

fun from_json_entries_go[a](remaining: List[(String, Json)], acc: List[(String, a)]) -> Result[String, List[(String, a)]] where a: FromJson =
    match remaining {
        Nil => Ok(reverse(acc)),
        Cons(pair, rest) => {
            let (k, v) = pair;
            let r: Result[String, a] = from_json(v);
            match r {
                Err(e) => Err(e),
                Ok(val) => recur(rest, Cons((k, val), acc)),
            }
        },
    }

fun from_json_entries[a](pairs: List[(String, Json)]) -> Result[String, List[(String, a)]] where a: FromJson =
    from_json_entries_go(pairs, Nil)

impl FromJson[Map[String, a]] where a: FromJson {
    fun from_json(j: Json) -> Result[String, Map[String, a]] = match j {
        JObj(m) => match from_json_entries(entries(m)) {
            Ok(pairs) => Ok(from_list(pairs)),
            Err(e) => Err(e),
        },
        _ => Err("expected object"),
    }
}
