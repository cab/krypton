import core/eq.{Eq}
import core/hash.{Hash}

pub type Json = JNull | JBool(Bool) | JNum(Float) | JStr(String)
              | JArr(List[Json]) | JObj(Map[String, Json])

extern java "krypton.runtime.JsonRuntime$JavaJson" as JavaJson {}

extern java "krypton.runtime.JsonRuntime" {
    fun staticParse[a](s: String) -> a
    fun staticSerialize(x: JavaJson) -> String
    fun staticRawType(x: JavaJson) -> Int
    fun staticRawBool(x: JavaJson) -> Bool
    fun staticRawNum(x: JavaJson) -> Float
    fun staticRawStr(x: JavaJson) -> String
    fun staticRawArr(x: JavaJson) -> Vec[JavaJson]
    fun staticRawEntryKeys(x: JavaJson) -> Vec[String]
    fun staticRawEntryValues(x: JavaJson) -> Vec[JavaJson]
    fun staticMkNull() -> JavaJson
    fun staticMkBool(v: Bool) -> JavaJson
    fun staticMkNum(v: Float) -> JavaJson
    fun staticMkStr(v: String) -> JavaJson
    fun staticNewArr() -> JavaJson
    fun staticArrPush(arr: JavaJson, item: JavaJson) -> Unit
    fun staticNewObj() -> JavaJson
    fun staticObjPut(obj: JavaJson, key: String, value: JavaJson) -> Unit
}

extern java "krypton.runtime.KryptonArray" {
    fun staticLength[a](xs: Vec[a]) -> Int
    fun staticGet[a, b](xs: Vec[a], index: Int) -> b
}

extern js "../extern/js/json.mjs" as JavaJson {}

extern js "../extern/js/json.mjs" {
    fun staticParse[a](s: String) -> a
    fun staticSerialize(x: JavaJson) -> String
    fun staticRawType(x: JavaJson) -> Int
    fun staticRawBool(x: JavaJson) -> Bool
    fun staticRawNum(x: JavaJson) -> Float
    fun staticRawStr(x: JavaJson) -> String
    fun staticRawArr(x: JavaJson) -> Vec[JavaJson]
    fun staticRawEntryKeys(x: JavaJson) -> Vec[String]
    fun staticRawEntryValues(x: JavaJson) -> Vec[JavaJson]
    fun staticMkNull() -> JavaJson
    fun staticMkBool(v: Bool) -> JavaJson
    fun staticMkNum(v: Float) -> JavaJson
    fun staticMkStr(v: String) -> JavaJson
    fun staticNewArr() -> JavaJson
    fun staticArrPush(arr: JavaJson, item: JavaJson) -> Unit
    fun staticNewObj() -> JavaJson
    fun staticObjPut(obj: JavaJson, key: String, value: JavaJson) -> Unit
}

extern js "../extern/js/array.mjs" {
    fun staticLength[a](xs: Vec[a]) -> Int
    fun staticGet[a, b](xs: Vec[a], index: Int) -> b
}

# ── Parse direction: JavaJson → Krypton Json ────────────────��─────

fun from_java(raw: JavaJson) -> Json = {
    let t = staticRawType(raw)
    if t == 0 { JNull }
    else if t == 1 { JBool(staticRawBool(raw)) }
    else if t == 2 { JNum(staticRawNum(raw)) }
    else if t == 3 { JStr(staticRawStr(raw)) }
    else if t == 4 {
        JArr(list_map(vec_to_list(staticRawArr(raw)), (item) -> from_java(item)))
    }
    else {
        let ks = vec_to_list(staticRawEntryKeys(raw))
        let vs = vec_to_list(staticRawEntryValues(raw))
        JObj(entries_to_map(ks, vs, empty()))
    }
}

fun entries_to_map(keys: List[String], values: List[JavaJson], acc: Map[String, Json]) -> Map[String, Json] =
    match (keys, values) {
        (Cons(k, kr), Cons(v, vr)) => entries_to_map(kr, vr, put(acc, k, from_java(v))),
        _ => acc,
    }

# ── Serialize direction: Krypton Json → JavaJson ──────────────────

fun build_arr(items: List[Json], arr: JavaJson) -> JavaJson =
    match items {
        Nil => arr,
        Cons(h, rest) => {
            staticArrPush(arr, to_java(h));
            build_arr(rest, arr)
        },
    }

fun build_obj(es: List[(String, Json)], obj: JavaJson) -> JavaJson =
    match es {
        Nil => obj,
        Cons(pair, rest) => {
            let (k, v) = pair;
            staticObjPut(obj, k, to_java(v));
            build_obj(rest, obj)
        },
    }

fun to_java(j: Json) -> JavaJson = match j {
    JNull => staticMkNull(),
    JBool(b) => staticMkBool(b),
    JNum(n) => staticMkNum(n),
    JStr(s) => staticMkStr(s),
    JArr(items) => build_arr(items, staticNewArr()),
    JObj(m) => build_obj(entries(m), staticNewObj()),
}

# ── Public API ────────────────────────────────────────────────────

pub fun parse_json(s: String) -> Result[String, Json] = {
    let pair = staticParse(s)
    let ok: Bool = staticGet(pair, 0)
    let payload = staticGet(pair, 1)
    if ok {
        Ok(from_java(payload))
    } else {
        Err(payload)
    }
}

pub fun json_to_string(j: Json) -> String = staticSerialize(to_java(j))

pub fun json_object(pairs: List[(String, Json)]) -> Json = JObj(from_list(pairs))

pub fun json_get(j: Json, key: String) -> Option[Json] =
    match j {
        JObj(m) => map_get(m, key),
        _ => None,
    }

