# Compiler intrinsic: primitive instance bodies are replaced by optimized JVM
# bytecode (lsub, dsub) at codegen time. The __krypton_intrinsic() marker tells
# the compiler to skip body type-checking and use bridge bytecode instead.
pub trait Sub[a] {
    fun sub(self: a, other: a) -> a
}
impl Sub[Int] { fun sub(a: Int, b: Int) -> Int = __krypton_intrinsic() }
impl Sub[Float] { fun sub(a: Float, b: Float) -> Float = __krypton_intrinsic() }
